<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">#1E1D1F</item>
        <item name="colorPrimaryDark">#1E1D1F</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="actionMenuTextAppearance">@style/MenuTextStyle</item>
        <!--按钮英文小写-->
        <item name="android:textAllCaps">false</item>
        <item name="android:windowBackground">@color/windowBackgroundColor</item>
    </style>

    <color name="windowBackgroundColor">#1E1D1F</color>


    <!--半沉浸式-->
    <style name="ImmersionTheme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:background">#1E1D1F</item>
    </style>

    <style name="ImmersionTransparentTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:background">#00000000</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>



    <style name="AppTheme2" parent="ImmersionTheme">

    </style>

    <style name="MenuTextStyle">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">18sp</item>
    </style>`


    <style name="DialogTheme" parent="@android:style/Theme.Dialog">
        <!-- 边框 -->
        <item name="android:windowFrame">@null</item>
        <!-- 是否浮现在activity之上 -->
        <item name="android:windowIsFloating">true</item>
        <!-- 半透明 -->
        <item name="android:windowIsTranslucent">true</item>
        <!-- 无标题 -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:background">@android:color/transparent</item>
        <!-- 背景透明 -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- 模糊 -->
        <item name="android:backgroundDimEnabled">true</item>
        <!-- 遮罩层 -->
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="DialogTheme2" parent="@style/ThemeOverlay.AppCompat.Dialog">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MaterialDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">

    </style>

    <style name="DrawerLayoutTheme" parent="AppTheme"></style>

    <style name="CardView.Content" parent="android:Widget">
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">24dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="processDialog" >
        <item name="android:windowIsFloating">true</item><!--是否浮现在activity之上-->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">false</item><!--半透明-->
        <item name="android:windowNoTitle">true</item><!--无标题-->
        <item name="android:windowBackground">@android:color/transparent</item><!--背景透明-->
        <item name="android:backgroundDimEnabled">true</item><!--模糊-->
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:alpha">0.3</item>
    </style>

    <style name="dialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <!--边框-->
        <item name="android:windowIsFloating">true</item>
        <!--是否浮现在activity之上-->
        <item name="android:windowIsTranslucent">false</item>
        <!--半透明-->
        <item name="android:windowNoTitle">true</item>
        <!--无标题-->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--背景透明-->
        <item name="android:backgroundDimEnabled">false</item>
        <!--模糊-->
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="dialog2" parent="@android:style/Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <!--边框-->
        <item name="android:windowIsFloating">true</item>
        <!--是否浮现在activity之上-->
        <item name="android:windowIsTranslucent">false</item>
        <!--半透明-->
        <item name="android:windowNoTitle">true</item>
        <!--无标题-->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!--背景透明-->
        <item name="android:backgroundDimEnabled">true</item>
        <!--模糊-->
        <item name="android:windowContentOverlay">@null</item>

    </style>

    <style name="dialog3">
        <item name="android:colorBackground">#757575</item>
    </style>

    <style name="MyCustomTabLayout" parent="Widget.Design.TabLayout">
        <item name="tabIndicatorColor">@color/tabUnSelectedTextColor</item>
        <item name="tabTextColor">@color/tabUnSelectedTextColor</item>
        <item name="tabIndicatorHeight">0dp</item>
        <item name="tabPaddingStart">12dp</item>
        <item name="tabPaddingEnd">12dp</item>
        <item name="android:background">@mipmap/bottom_bg</item>
        <item name="tabSelectedTextColor">@color/tabSelectedTextColor</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="NavTabLayout" parent="Widget.Design.TabLayout">
        <item name="tabIndicatorColor">@color/tabSelectedTextColor</item>
        <item name="tabTextColor">@color/tabUnSelectedTextColor</item>
        <item name="tabIndicatorHeight">4dp</item>
        <item name="tabPaddingStart">12dp</item>
        <item name="tabPaddingEnd">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@color/colorPrimaryDark</item>
        <item name="tabSelectedTextColor">@color/tabSelectedTextColor</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.AppCompat.Button">
        <item name="textAllCaps">false</item>
    </style>


    <style name="popShowAnim">
        <item name="android:windowEnterAnimation">@anim/pop_alpha_in</item>
        <item name="android:windowExitAnimation">@anim/pop_alpha_out</item>
    </style>


    <style name="MyEditText" parent="Theme.AppCompat.Light">
        <item name="colorControlNormal">#373940</item>
        <item name="colorControlActivated">#373940</item>
    </style>

    <declare-styleable name="PointerCircleBar">
        <attr name="animTime" />
    </declare-styleable>

    <declare-styleable name="SpeedCircleBar">
        <attr name="animTime" />
    </declare-styleable>

    <declare-styleable name="MagicRPMTextView">
        <attr name="animTime" />
    </declare-styleable>


</resources>
