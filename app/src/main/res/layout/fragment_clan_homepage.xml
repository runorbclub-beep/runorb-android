<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/layBottom"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
      android:layout_width="match_parent"
      android:layout_height="match_parent">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="20dp"
          android:layout_marginStart="15dp"
          android:textSize="14sp"
          android:textColor="#FFFFFF"
          android:text="@string/label_clan_introduction"/>

        <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp"
          android:layout_marginStart="15dp"
          android:layout_marginEnd="15dp"
          app:cardCornerRadius="6dp"
          app:cardBackgroundColor="#28272A"
          app:cardElevation="2dp"
          android:orientation="vertical">

          <TextView
            android:id="@+id/tvClanIntroduction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:maxLines="3"
            android:textColor="#ADADAD"
            android:textSize="12sp"
            tools:text="华为深圳分部团队华为深圳分部团队华为深圳分部团队华为深圳分部团队华为深圳分部团队华为深圳分部团队华为深圳分部团队华为深圳 太热太热特认同范德萨发生的发生的分部"/>

          <ImageView
            android:id="@+id/ivOpenIntroduction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="@null"
            android:layout_gravity="bottom"
            android:src="@mipmap/item_more2" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="20dp"
          android:layout_marginStart="15dp"
          android:layout_marginEnd="15dp"
          android:orientation="horizontal">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:text="@string/label_clan_average_score"/>

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#ADADAD"
            android:text="@string/label_clan_average_score_vice"/>

          <TextView
            android:id="@+id/tvGotoClanScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableEnd="@mipmap/item_more"
            android:visibility="gone"
            tools:visibility="visible"
            android:textSize="14sp"
            android:textColor="#ADADAD"
            android:text="@string/lbl_detail"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp"
          android:layout_marginStart="15dp"
          android:layout_marginEnd="15dp"
          app:cardCornerRadius="6dp"
          app:cardBackgroundColor="#28272A"
          app:cardElevation="2dp"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:showDividers="middle"
            android:divider="@drawable/divider_horizontal"
            android:dividerPadding="15dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center_horizontal"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#ADADAD"
                android:text="@string/turn_speed_2"/>

              <TextView
                android:id="@+id/tvMaxSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:textColor="#FDE833"
                tools:text="13260"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888888"
                android:text="@string/turn_speed_unit_2"/>

            </LinearLayout>

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center_horizontal"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#ADADAD"
                android:text="@string/turn_one_minute_2"/>

              <TextView
                android:id="@+id/tvOneMinute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:textColor="#FDE833"
                tools:text="1.89"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888888"
                android:text="@string/turn_one_minute_unit_2"/>

            </LinearLayout>


            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center_horizontal"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#ADADAD"
                android:text="@string/turn_exponent_2"/>

              <TextView
                android:id="@+id/tvExponent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:textColor="#FDE833"
                tools:text="108.41"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888888"
                android:text="@string/turn_exponent_unit_2"/>

            </LinearLayout>

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center_horizontal"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#ADADAD"
                android:text="@string/turn_marathon_2"/>

              <TextView
                android:id="@+id/tvMarathon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="16sp"
                android:textColor="#FDE833"
                tools:text="00:29:41"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888888"
                android:text="@string/turn_marathon_unit_2"/>

            </LinearLayout>

          </LinearLayout>

        </androidx.cardview.widget.CardView>

      </LinearLayout>

    </androidx.core.widget.NestedScrollView>

  </LinearLayout>

  <LinearLayout
    android:id="@+id/layBottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    android:orientation="vertical"
    android:paddingTop="13dp"
    android:paddingBottom="13dp"
    android:visibility="gone"
    tools:visibility="visible">

    <androidx.cardview.widget.CardView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      app:cardBackgroundColor="#ADADAD"
      app:cardCornerRadius="19dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="10dp"
        android:text="@string/state_will_pending"
        android:textColor="#1E1D1F"
        android:textSize="14sp"
        android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

  </LinearLayout>

</RelativeLayout>

