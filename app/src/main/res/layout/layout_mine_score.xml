<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_content"
    android:orientation="vertical">

    <include
        layout="@layout/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


    <RadioGroup
        android:id="@+id/rgDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbWeek"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:background="@drawable/selector_score_date_title"
            android:button="@null"
            android:textAllCaps="false"
            android:checked="true"
            android:gravity="center"
            android:text="@string/week"
            android:textColor="#ffffff"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/rbMonth"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:button="@null"
            android:textAllCaps="false"
            android:checked="false"
            android:gravity="center"
            android:text="@string/month"
            android:textColor="#ffffff"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/rbYear"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:button="@null"
            android:textAllCaps="false"
            android:checked="false"
            android:gravity="center"
            android:text="@string/year"
            android:textColor="#ffffff"
            android:textSize="18sp" />
    </RadioGroup>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivArrowLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@mipmap/btn_return"
            android:layout_gravity="center_vertical"
            android:layout_marginRight="20dp"
            android:adjustViewBounds="true"
            android:clickable="true"
            />

        <TextView
            android:id="@+id/tv_info_date"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text=""
            android:textColor="#ffffffff"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/ivArrowRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="20dp"
            android:adjustViewBounds="true"
            android:background="@mipmap/btn_return_right"
            android:clickable="true"
            />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:orientation="horizontal">
        <!--图表控件 -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lcTurnCharts"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="180dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@mipmap/mine_score_item_bg">

                <ImageView
                    android:id="@+id/img_device"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="25dp"
                    android:adjustViewBounds="true"
                    android:background="@mipmap/icon_time" />

                <TextView
                    android:id="@+id/tv_info_time"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="40dp"
                    android:layout_toRightOf="@+id/img_device"
                    android:text="00:00:00"
                    android:textColor="#ffffffff"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="36dp"
                    android:layout_toRightOf="@+id/tv_info_time"
                    android:layout_centerHorizontal="true"
                    android:text="@string/lbl_duration"
                    android:textColor="#ff767779"
                    android:textSize="12sp" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@mipmap/mine_score_item_bg">

                <ImageView
                    android:id="@+id/img_turn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="25dp"
                    android:adjustViewBounds="true"
                    android:background="@mipmap/icon_turn" />

                <TextView
                    android:id="@+id/tv_info_turn"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="36dp"
                    android:layout_toRightOf="@+id/img_turn"
                    android:text="0"
                    android:textColor="#ffffffff"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="36dp"
                    android:layout_toRightOf="@+id/tv_info_turn"
                    android:layout_alignParentRight="true"
                    android:text="@string/lbl_speex"
                    android:textColor="#ff767779"
                    android:textSize="12sp" />


            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@mipmap/mine_score_item_bg">

                <ImageView
                    android:id="@+id/img_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="25dp"
                    android:adjustViewBounds="true"
                    android:background="@mipmap/icon_distance" />

                <TextView
                    android:id="@+id/tv_info_distance"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="40dp"
                    android:layout_toRightOf="@+id/img_distance"
                    android:text="0"
                    android:textColor="#ffffffff"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="36dp"
                    android:layout_toRightOf="@+id/tv_info_distance"
                    android:text="@string/lbl_distance"
                    android:textColor="#ff767779"
                    android:textSize="12sp" />


            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@mipmap/mine_score_item_bg">

                <ImageView
                    android:id="@+id/img_win_times"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="25dp"
                    android:adjustViewBounds="true"
                    android:background="@mipmap/icon_endurance" />

                <TextView
                    android:id="@+id/tv_info_win_times"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="40dp"
                    android:layout_toRightOf="@+id/img_win_times"
                    android:text="0"
                    android:textColor="#ffffffff"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="36dp"
                    android:layout_toRightOf="@+id/tv_info_win_times"
                    android:text="@string/lbl_win_times"
                    android:textColor="#ff767779"
                    android:textSize="12sp" />


            </RelativeLayout>
        </LinearLayout>
    </ScrollView>


</LinearLayout>