<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/lyRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <TextView
    android:id="@+id/tvSlogan"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toTopOf="@+id/ivDynamicBall"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintVertical_bias="0.9"
    android:textColor="#F7DC29"
    android:textSize="24sp"
    android:text="@string/app_desc" />

  <ImageView
    android:id="@+id/ivDynamicBall"
    android:layout_width="200dp"
    android:layout_height="200dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toTopOf="@+id/layBottom"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:src="@drawable/ball_dynamic"/>

  <LinearLayout
    android:id="@+id/layBottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    android:background="@mipmap/bg_startup_bottom_arc"
    android:gravity="center"
    android:orientation="horizontal">

    <androidx.cardview.widget.CardView
      android:layout_width="37dp"
      android:layout_height="37dp"
      app:cardBackgroundColor="@android:color/transparent"
      app:cardCornerRadius="8dp">

      <ImageView
        android:layout_width="37dp"
        android:layout_height="37dp"
        android:src="@mipmap/logo"/>

    </androidx.cardview.widget.CardView>

    <ImageView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="9dp"
      android:src="@mipmap/logo_app_name"/>

  </LinearLayout>


  <FrameLayout
    android:id="@+id/fySplash"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
      android:id="@+id/ivSplash"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:scaleType="centerCrop"
      android:layout_gravity="center"/>

    <ImageView
      android:id="@+id/ivSplashLogo"
      android:layout_width="160dp"
      android:layout_height="260dp"
      android:layout_gravity="center"
      android:layout_marginBottom="130dp"/>

  </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>