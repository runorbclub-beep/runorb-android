<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="220dp"
    android:layout_gravity="center"
    android:background="@drawable/shape_choose_photo"
    android:orientation="vertical">


    <TextView
        android:id="@+id/tvOntPhoto"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:clickable="true"
        android:text="@string/lbl_one_photo"
        android:gravity="center_vertical"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:textColor="#ffffffff"
        android:textSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/tvAlbum"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/lbl_album"
        android:gravity="center_vertical"
        android:clickable="true"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:layout_below="@+id/tvOntPhoto"
        android:textColor="#ffffffff"
        android:textSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/tvBigPhoto"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:text="@string/lbl_big_photo"
        android:clickable="true"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:layout_below="@+id/tvAlbum"
        android:textColor="#ffffffff"
        android:textSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/tvCancel"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:clickable="true"
        android:text="@string/btn_cancel"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:textColor="#ff767779"
        android:layout_margin="10dp"
        android:textSize="@dimen/text_size_16" />

</RelativeLayout>