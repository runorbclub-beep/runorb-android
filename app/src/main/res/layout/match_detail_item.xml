<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:paddingTop="8dp"
  android:paddingBottom="8dp"
  android:background="@color/bg_content"
  android:orientation="horizontal">

  <FrameLayout
    android:layout_width="51dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical">

    <ImageView
      android:id="@+id/img_rank"
      android:layout_width="24dp"
      android:layout_height="25dp"
      android:layout_gravity="center"
      android:adjustViewBounds="true"
      android:background="@mipmap/match_range_1" />

    <TextView
      android:id="@+id/tvRank"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:visibility="gone"
      android:textColor="#ffffffff"
      android:textSize="18sp"
      tools:text="2" />

  </FrameLayout>

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:layout_marginRight="15dp"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="58dp"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="-25dp"
      android:layout_toRightOf="@+id/fyHead"
      android:background="@drawable/shape_person_item"
      android:gravity="center_vertical"
      android:orientation="vertical">

      <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="37dp"
        android:drawableRight="@mipmap/ic_man"
        android:drawablePadding="6dp"
        android:textColor="#ffffffff"
        android:textSize="13sp"
        tools:text="笑对人生" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginLeft="37dp"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvDistance"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#ADADAD"
          android:textSize="10sp"
          tools:text="最高转速：1.283" />

        <View
          android:layout_width="1dp"
          android:layout_height="match_parent"
          android:layout_marginTop="1dp"
          android:layout_marginBottom="1dp"
          android:layout_marginLeft="10dp"
          android:layout_marginRight="10dp"
          android:background="#ADADAD"/>

        <TextView
          android:id="@+id/tvSpeed"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#ADADAD"
          android:textSize="10sp"
          tools:text="距离：14270km" />

      </LinearLayout>

    </LinearLayout>

    <FrameLayout
      android:id="@+id/fyHead"
      android:layout_width="58dp"
      android:layout_height="58dp"
      android:background="@mipmap/match_range_head_box">

      <ImageView
        android:id="@+id/ivHead"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:adjustViewBounds="true" />

    </FrameLayout>

  </RelativeLayout>

</LinearLayout>