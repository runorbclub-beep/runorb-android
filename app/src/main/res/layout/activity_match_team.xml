<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_content"
    android:orientation="vertical">

    <include
        android:id="@+id/lyHeader"
        layout="@layout/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_match_pk_id_no"
            android:textColor="#ffffffff"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvTimeValid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:clickable="true"
            android:text="@string/lbl_refresh_id"
            android:textColor="#fff9e85b"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRoomID1"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvRoomID2"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvRoomID3"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvRoomID4"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvRoomID5"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvRoomID6"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_weight="1.0"
            android:background="@drawable/match_item"
            android:gravity="center"
            android:text=" "
            android:textColor="#ffffffff"
            android:textSize="18sp" />

    </LinearLayout>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|left"
            android:text="@string/lbl_match_time"
            android:textColor="#ffffffff"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/edtTime"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right"
            android:layout_toLeftOf="@+id/tvTime"
            android:background="@null"
            android:gravity="right"
            android:hint="请输入运动时间(分钟)"
            android:inputType="number"
            android:text="5"
            android:textColor="#ffffffff"
            android:textColorHint="#ffffffff"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_gravity="center|right"
            android:text="@string/lbl_double_match_time"
            android:textColor="#ffffffff"
            android:textSize="16sp" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|left"
            android:text="@string/lbl_match_max_person"
            android:textColor="#ffffffff"
            android:textSize="16sp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right"
            android:gravity="right"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/edtMax"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center|right"
                android:background="@null"
                android:gravity="right"
                android:layout_marginRight="20dp"
                android:hint="@string/lbl_input_match_person"
                android:inputType="number"
                tools:text="2"
                android:textColor="#ffffffff"
                android:textColorHint="#767779"
                android:textCursorDrawable="@drawable/color_cursor"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/img_match_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:src="@mipmap/item_more" />
        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|left"
            android:text="@string/lbl_team_name"
            android:textColor="#ffffffff"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtRed"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right"
            android:background="@null"
            android:gravity="right"
            android:hint="@string/lbl_match_input_name"
            android:text=""
            android:textColor="#ffffffff"
            android:textColorHint="#767779"
            android:textCursorDrawable="@drawable/color_cursor"
            android:textSize="16sp" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|left"
            android:text="@string/lbl_other_team_name"
            android:textColor="#ffffffff"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtBlue"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right"
            android:background="@null"
            android:gravity="right"
            android:hint="@string/lbl_match_input_name2"
            android:text=""
            android:textColor="#ffffffff"
            android:textColorHint="#767779"
            android:textCursorDrawable="@drawable/color_cursor"
            android:textSize="16sp" />
    </FrameLayout>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center"
        android:layout_margin="20dp"
        android:background="@mipmap/match_pk_confirm"
        android:text="@string/btn_confirm2"
        android:textAllCaps="false"
        android:textSize="@dimen/text_16" />
</LinearLayout>