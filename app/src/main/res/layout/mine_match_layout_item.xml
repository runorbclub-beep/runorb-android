<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  tools:background="#25282C"
  android:orientation="horizontal">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp">

    <ImageView
      android:id="@+id/tvImage"
      android:layout_width="100dp"
      android:layout_height="100dp"
      android:layout_marginTop="5dp"
      android:layout_marginBottom="5dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:src="@mipmap/match_sub_logo_default" />

    <TextView
      android:id="@+id/tvStatus"
      android:layout_width="56dp"
      android:layout_height="16dp"
      app:layout_constraintBottom_toBottomOf="@+id/tvImage"
      app:layout_constraintLeft_toLeftOf="@+id/tvImage"
      android:background="@drawable/mark_match_status_list_item_playing"
      android:layout_gravity="bottom"
      android:gravity="center_vertical"
      android:paddingLeft="10dp"
      android:textColor="#ff1a1d20"
      android:textSize="10sp"
      tools:text="#" />

    <ImageView
      android:id="@+id/ivHot"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/tvImage"
      app:layout_constraintBottom_toTopOf="@+id/tvImage"
      app:layout_constraintRight_toRightOf="@+id/tvImage"
      android:visibility="invisible"
      tools:visibility="visible"
      android:src="@mipmap/hot"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:orientation="vertical">

    <TextView
      android:id="@+id/tvTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_centerVertical="true"
      android:layout_marginLeft="8dp"
      android:layout_marginRight="20dp"
      android:textColor="#FFFFFF"
      android:textSize="14sp"
      tools:text="2021年度总决赛-100米" />

    <TextView
      android:id="@+id/tvTime"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:singleLine="true"
      android:layout_marginRight="10dp"
      android:layout_centerVertical="true"
      android:layout_marginLeft="8dp"
      android:textColor="#999999"
      android:textSize="12sp"
      tools:text="2020/01/02" />

    <TextView
      android:id="@+id/tvNum"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerVertical="true"
      android:layout_marginLeft="8dp"
      android:textColor="#999999"
      android:textSize="12sp"
      tools:text="@string/lbl_match_sign_num" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_gravity="bottom"
      android:layout_marginLeft="10dp"
      android:layout_marginTop="5dp"
      android:gravity="bottom"
      android:orientation="horizontal">

      <Button
        android:id="@+id/btnAttendDetail"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:minWidth="72dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:layout_gravity="bottom"
        android:background="@drawable/selector_login_status_btn"
        android:text="@string/lbl_match_sign_now"
        android:textAllCaps="false"
        android:textSize="12sp" />

    </LinearLayout>

  </LinearLayout>

</LinearLayout>

