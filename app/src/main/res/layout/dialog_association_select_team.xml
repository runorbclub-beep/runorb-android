<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:orientation="vertical">

  <RelativeLayout
    android:layout_width="332dp"
    android:layout_height="wrap_content">

    <ImageView
      android:id="@+id/ivClose"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentRight="true"
      android:src="@mipmap/close_yellow" />

    <LinearLayout
      android:id="@+id/layMain"
      android:layout_width="332dp"
      android:layout_height="532dp"
      android:orientation="vertical"
      android:layout_below="@+id/ivClose"
      android:background="@drawable/bg_dialog_select_team">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#F7DC29"
        android:text="@string/association_select_team_tip"/>

      <EditText
        android:id="@+id/et_searchview"
        android:layout_marginTop="5dip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:background="@drawable/bg_search_edit"
        android:drawableLeft="@mipmap/ic_search"
        android:drawablePadding="6dp"
        android:hint="@string/hint_dialog_search_team"
        android:textColorHint="#FFFFFF"
        android:singleLine="true"
        android:layout_margin="10dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="10dp"
        android:orientation="horizontal">

        <ListView
          android:id="@+id/name_listview"
          android:layout_width="0dp"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:scrollbars="none"
          android:divider="@null" />

        <!-- 右侧供选择的列表 -->
        <com.cloud.runball.module.match_football_association.widget.widget.SideBarView
          android:id="@+id/sideBarView"
          android:layout_width="20dp"
          android:layout_height="match_parent"
          android:layout_marginLeft="5dp"
          android:layout_marginRight="5dp"
          android:layout_gravity="right" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvSubmit"
          android:layout_width="226dp"
          android:layout_height="wrap_content"
          android:paddingTop="8dp"
          android:paddingBottom="8dp"
          android:paddingLeft="36dp"
          android:paddingRight="36dp"
          android:layout_marginLeft="12.5dp"
          android:gravity="center"
          android:background="@drawable/selector_radius_yellow"
          android:textColor="#25282C"
          android:textSize="14sp"
          android:text="@string/btn_ok"/>

      </LinearLayout>

    </LinearLayout>

  </RelativeLayout>

</LinearLayout>