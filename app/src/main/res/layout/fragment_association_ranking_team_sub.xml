<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  xmlns:tools="http://schemas.android.com/tools"
  android:background="@color/bg_content"
  android:orientation="vertical">

  <com.jcodecraeer.xrecyclerview.XRecyclerView
    android:id="@+id/recyclerview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/lyBottom"
    android:layout_gravity="center" />

  <RelativeLayout
    android:id="@+id/ryEmpty"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="150dp"
    android:visibility="gone">

    <ImageView
      android:id="@+id/ivEmpty"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:background="@mipmap/rank_empty" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerHorizontal="true"
      android:layout_marginTop="25dp"
      android:layout_below="@+id/ivEmpty"
      android:text="@string/lbl_empty2"
      android:textColor="#ffffffff"
      android:textSize="15sp" />

  </RelativeLayout>

  <LinearLayout
    android:id="@+id/lyBottom"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="true"
    android:layout_marginBottom="0dp"
    android:background="#464A71"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:visibility="gone"
    tools:visibility="visible">

    <TextView
      android:id="@+id/tvRankNum"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="21dp"
      android:gravity="center_vertical"
      android:textColor="#fff9e85b"
      android:textSize="12sp"
      tools:text="101" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="9dp"
      android:orientation="horizontal"
      android:paddingRight="14dp">

      <TextView
        android:id="@+id/tvUserName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:drawablePadding="5dp"
        android:gravity="center_vertical"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        tools:text="笑看人生" />

      <TextView
        android:id="@+id/tvUserSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F5BE0A"
        android:textSize="12sp"
        tools:text="342.33(rpm)" />

      <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@mipmap/btn_return_right"/>

    </LinearLayout>

  </LinearLayout>

</RelativeLayout>