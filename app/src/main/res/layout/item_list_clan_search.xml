<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:paddingTop="10dp"
  android:paddingBottom="10dp"
  android:orientation="vertical">

  <ImageView
    android:id="@+id/ivHead"
    android:layout_width="50dp"
    android:layout_height="50dp"
    android:padding="1dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    android:contentDescription="@null"
    android:layout_gravity="center"
    android:adjustViewBounds="true"
    android:background="@drawable/border_rectangle_portrait_top" />

  <TextView
    android:id="@+id/tvName"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toTopOf="@+id/tvArea"
    app:layout_constraintStart_toEndOf="@+id/ivHead"
    app:layout_constrainedWidth="true"
    app:layout_constraintHorizontal_bias="0"
    android:singleLine="true"
    android:layout_marginStart="10dp"
    android:drawablePadding="4dp"
    android:gravity="center_vertical"
    android:textColor="#ffffffff"
    android:textSize="13sp"
    tools:text="笑对人生" />

  <TextView
    android:id="@+id/tvArea"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@+id/tvName"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toEndOf="@+id/ivHead"
    app:drawableLeftCompat="@mipmap/local_red"
    android:layout_marginStart="10dp"
    android:textColor="#C7C7C7"
    android:textSize="9sp"
    tools:text="深圳" />

  <View
    android:id="@+id/vDivider"
    android:layout_width="1dp"
    android:layout_height="10dp"
    app:layout_constraintTop_toTopOf="@+id/tvArea"
    app:layout_constraintBottom_toBottomOf="@+id/tvArea"
    app:layout_constraintStart_toEndOf="@+id/tvArea"
    android:layout_marginTop="1dp"
    android:layout_marginBottom="1dp"
    android:layout_marginStart="10dp"
    android:background="#C7C7C7"/>

  <TextView
    android:id="@+id/tvMemberCount"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="@+id/tvArea"
    app:layout_constraintBottom_toBottomOf="@+id/tvArea"
    app:layout_constraintStart_toEndOf="@+id/vDivider"
    android:layout_marginStart="10dp"
    android:textColor="#C7C7C7"
    android:textSize="9sp"
    tools:text="成员数 11人" />

  <ImageView
    android:id="@+id/ivMore"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:src="@mipmap/item_more"/>

</androidx.constraintlayout.widget.ConstraintLayout>