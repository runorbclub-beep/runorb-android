<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:background="#25000000">

  <androidx.core.widget.NestedScrollView
    android:id="@+id/lyScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical">

      <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lyContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:paddingBottom="33dp"
        android:background="@mipmap/bg_share_card"
        android:layout_gravity="center">

        <ImageView
          android:id="@+id/ivPortrait"
          android:layout_width="55dp"
          android:layout_height="55dp"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintLeft_toLeftOf="parent"
          android:layout_marginTop="46dp"
          android:layout_marginLeft="33dp"
          android:background="@drawable/border_portrait"/>

        <TextView
          android:id="@+id/tvUserName"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/ivPortrait"
          app:layout_constraintBottom_toTopOf="@+id/tvArea"
          app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
          android:layout_marginLeft="8dp"
          android:gravity="center"
          android:textColor="#ffffff"
          android:textSize="14sp"
          tools:text="aaaa"/>

        <TextView
          android:id="@+id/tvArea"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/tvUserName"
          app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
          app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
          android:layout_marginLeft="5dp"
          android:drawableLeft="@mipmap/icon_pos"
          android:gravity="center"
          android:textColor="#F9E85B"
          android:textSize="12sp"
          tools:text="广东 深圳"/>

        <RelativeLayout
          android:id="@+id/layFlag"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          android:layout_marginTop="20dp"
          android:layout_marginRight="20dp"
          android:paddingBottom="20dp"
          android:background="@mipmap/flag_red"
          android:textSize="22sp"
          android:textColor="#F9E85B"
          android:textStyle="bold">

          <androidx.cardview.widget.CardView
            android:id="@+id/ivLogo"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="11dp"
            android:layout_centerHorizontal="true">

            <ImageView
              android:layout_width="22dp"
              android:layout_height="22dp"
              android:src="@mipmap/logo" />

          </androidx.cardview.widget.CardView>

          <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/ivLogo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="2dp"
            android:text="@string/app_name"
            android:textColor="#F9E85B"
            android:textSize="8sp" />

          <TextView
            android:id="@+id/tvLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvAppName"
            android:layout_marginTop="2dp"
            android:layout_centerHorizontal="true"
            android:textSize="16sp"
            android:textColor="#F9E85B"
            android:text="@string/lbl_other_match_flag"/>

        </RelativeLayout>

        <ImageView
          android:id="@+id/ivClose"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/layFlag"
          app:layout_constraintBottom_toTopOf="@+id/layFlag"
          app:layout_constraintLeft_toRightOf="@+id/layFlag"
          app:layout_constraintRight_toRightOf="@+id/layFlag"
          android:src="@mipmap/close_yellow"/>

        <LinearLayout
          android:id="@+id/layAchievement"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/tvArea"
          android:layout_marginTop="39dp"
          android:layout_marginLeft="20dp"
          android:layout_marginRight="20dp"
          android:paddingTop="26dp"
          android:paddingBottom="32dp"
          android:paddingLeft="17dp"
          android:paddingRight="17dp"
          android:background="@mipmap/bg_share_data_upup"
          android:orientation="vertical">

          <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#ffffff"
            android:textSize="18sp"
            tools:text="2021-11-23"/>

          <TextView
            android:id="@+id/tvUpupStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            tools:textColor="#E26863"
            tools:text="@string/lbl_other_match_status_2"/>

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="19dp"
            android:paddingTop="6dp"
            android:paddingLeft="9dp"
            android:paddingRight="9dp"
            android:background="@mipmap/bg_share_data_horse"
            android:orientation="horizontal">

            <LinearLayout
              android:layout_width="96dp"
              android:layout_height="wrap_content"
              android:gravity="center_vertical"
              android:orientation="vertical">

              <ImageView
                android:id="@+id/ivHorse"
                android:layout_width="95dp"
                android:layout_height="76dp"
                android:layout_gravity="center"
                tools:background="@drawable/horse_3_stop"/>

              <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="96dp"
                android:layout_height="28dp"
                android:background="@mipmap/bg_share_data_horse_title">

                <TextView
                  android:id="@+id/tvHorseNum"
                  android:layout_width="0dp"
                  android:layout_height="match_parent"
                  app:layout_constraintDimensionRatio="h,1:1"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintLeft_toLeftOf="parent"
                  android:gravity="center"
                  android:textColor="#FFFFFF"
                  android:textSize="13sp"
                  tools:text="1号"/>

                <TextView
                  android:id="@+id/tvHorseTitle"
                  android:layout_width="wrap_content"
                  android:layout_height="match_parent"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintLeft_toRightOf="@+id/tvHorseNum"
                  app:layout_constraintRight_toRightOf="parent"
                  app:layout_constrainedWidth="true"
                  app:layout_constraintHorizontal_bias ="0.3"
                  android:gravity="center"
                  android:textColor="#FFFFFF"
                  android:textSize="10sp"
                  tools:text="赤兔马"/>

              </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="match_parent"
              android:layout_weight="2"
              android:gravity="center_vertical"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvHelpPlayers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@mipmap/ic_lightning"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_marginLeft="12dp"
                android:gravity="center_vertical"
                android:textSize="12sp"
                android:textColor="#F9E85B"
                android:text="@string/lbl_main_match_match_help_players_label"
                tools:text="人数：1000000000000"/>

              <TextView
                android:id="@+id/tvHelpDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@mipmap/ic_lightning"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_marginLeft="12dp"
                android:gravity="center_vertical"
                android:textSize="12sp"
                android:textColor="#F9E85B"
                android:text="@string/lbl_main_match_match_help_distance_label"
                tools:text="距离：10000000000000000000000km"/>

              <TextView
                android:id="@+id/tvRanking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableLeft="@mipmap/ic_lightning"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_marginLeft="12dp"
                android:gravity="center_vertical"
                android:textSize="12sp"
                android:textColor="#F9E85B"
                android:text="@string/lbl_main_match_match_ranking_label"
                tools:text="排名：10000000000000000000000"/>

            </LinearLayout>

          </LinearLayout>


          <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_gravity="center"
            android:orientation="vertical">

            <TextView
              android:id="@+id/tvMyHelpDistance"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:layout_marginBottom="5dp"
              android:drawableLeft="@mipmap/ic_data_item_upup"
              android:drawablePadding="3dp"
              android:textStyle="bold"
              android:textColor="#FFFFFF"
              android:textSize="14sp"
              tools:text="我的助力距离：38km"/>

            <TextView
              android:id="@+id/tvMyHelpTime"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:layout_marginBottom="5dp"
              android:drawableLeft="@mipmap/ic_data_item_upup"
              android:drawablePadding="3dp"
              android:textStyle="bold"
              android:textColor="#FFFFFF"
              android:textSize="14sp"
              tools:text="总助力时间：38min"/>

            <TextView
              android:id="@+id/tvScore"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="5dp"
              android:layout_marginBottom="5dp"
              android:drawableLeft="@mipmap/ic_data_item_upup"
              android:drawablePadding="3dp"
              android:textStyle="bold"
              android:textColor="#FFFFFF"
              android:textSize="14sp"
              tools:text="获得积分：38343"/>

          </LinearLayout>

        </LinearLayout>

        <ImageView
          android:id="@+id/ivQrCode"
          android:layout_width="74dp"
          android:layout_height="74dp"
          app:layout_constraintTop_toBottomOf="@+id/layAchievement"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          android:layout_marginTop="30dp"
          android:background="@mipmap/bg_qr_code"/>

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/ivQrCode"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          android:layout_marginTop="3dp"
          android:textColor="#F9E85B"
          android:textSize="12sp"
          android:text="@string/share_qr_code_tip"/>

      </androidx.constraintlayout.widget.ConstraintLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvMore"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginRight="15dp"
          android:paddingTop="10dp"
          android:paddingBottom="10dp"
          android:paddingLeft="24dp"
          android:paddingRight="24dp"
          android:background="@drawable/btn_other"
          android:textSize="15sp"
          android:textColor="#F5BE0A"
          android:textStyle="bold"
          android:visibility="gone"
          android:text="@string/lbl_share_more"/>

        <TextView
          android:id="@+id/tvShare"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginLeft="15dp"
          android:paddingTop="10dp"
          android:paddingBottom="10dp"
          android:paddingLeft="24dp"
          android:paddingRight="24dp"
          android:background="@drawable/btn_share"
          android:textSize="15sp"
          android:textColor="#1A1D20"
          android:textStyle="bold"
          android:text="@string/lbl_share_btn"/>

      </LinearLayout>

    </LinearLayout>

  </androidx.core.widget.NestedScrollView>

</FrameLayout>
