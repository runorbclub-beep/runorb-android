<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <LinearLayout
        android:id="@+id/lyContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center"
        android:background="@mipmap/win_bg0"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:gravity="center"
            android:text=""
            android:textColor="#ff85a6be"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/lbl_match_attend_complete"
            android:textColor="#FDFD30"
            android:textSize="48sp" />


        <TextView
            android:id="@+id/tvResult2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:text=""
            android:textColor="#ff00fff1"
            android:textSize="16sp"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPerson"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1.0"
                android:text="@string/lbl_match_attend_persons"
                android:textColor="#85A6BE"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_weight="1.0"
                android:gravity="right"
                android:text="@string/lbl_match_attend_distance"
                android:textColor="#85A6BE"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/ivConfirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lyContent"
        android:layout_centerHorizontal="true"
        android:layout_gravity="center"
        android:layout_marginTop="-20dp"
        android:clickable="true"
        android:visibility="gone"
        android:background="@mipmap/win_btn_confirm" />


    <ImageView
        android:id="@+id/ivWin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/lyContent"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-100dp"
        android:background="@mipmap/win_bg1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/ivWin"
        android:layout_marginTop="-20dp"
        android:gravity="center"
        android:text="@string/lbl_match_attend_title"
        android:textColor="#fffcd61c"
        android:textSize="40sp" />

</RelativeLayout>