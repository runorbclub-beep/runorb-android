<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    android:minHeight="?attr/actionBarSize"
    app:navigationIcon="@mipmap/btn_return"
    android:background="@drawable/bg_page_header_clock_in">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="#FFFFFF"
      android:textSize="16sp"
      android:text="@string/title_page_clock_in"/>

    <ImageView
      android:id="@+id/ivDataTotal"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_marginRight="17dp"
      android:layout_gravity="right"
      android:src="@mipmap/ic_data_total"/>

    <ImageView
      android:id="@+id/ivSync"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_marginRight="10dp"
      android:layout_gravity="right"
      android:src="@mipmap/sync_white"/>

  </androidx.appcompat.widget.Toolbar>

  <LinearLayout
    android:id="@+id/layUserInfo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:paddingTop="17dp"
    android:paddingBottom="10dp"
    app:layout_constraintTop_toBottomOf="@+id/toolbar"
    android:background="@drawable/bg_page_header_clock_in"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/ivUserPortrait"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_marginLeft="19dp"
      android:background="@drawable/border_portrait"
      android:padding="1dp" />

    <TextView
      android:id="@+id/tvDayDistance"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginLeft="5dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      tools:text="今日累计摇跑15km"/>

    <TextView
      android:id="@+id/tvSelectDate"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#FFFFFF"
      android:textSize="11sp"
      tools:text="2021年11月"/>

    <ImageView
      android:layout_width="16dp"
      android:layout_height="16dp"
      android:layout_marginRight="31dp"
      android:src="@mipmap/arrow_down"/>

  </LinearLayout>

  <androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:layout_constrainedHeight="true"
    app:layout_constraintTop_toBottomOf="@+id/layUserInfo"
    app:layout_constraintBottom_toTopOf="@+id/tvGotoClockIn"
    android:layout_marginBottom="10dp">

    <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent">

      <View
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_page_header_clock_in"/>

      <com.cloud.runball.widget.calendar.ClockInCalendarView
        android:id="@+id/layCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:layout_height="0dp"
        tools:layout_constraintDimensionRatio="h,7:6"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:background="@drawable/bg_clock_in_calendar"/>

      <TextView
        android:id="@+id/tvLabelList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/layCalendar"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="15dp"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:text="@string/label_clock_in_target"/>

      <TextView
        android:id="@+id/tvMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/layCalendar"
        app:layout_constraintRight_toLeftOf="@+id/ivMore"
        android:layout_marginTop="15dp"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:text="@string/more_plan"/>

      <ImageView
        android:id="@+id/ivMore"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:layout_constraintTop_toTopOf="@+id/tvMore"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/tvMore"
        android:layout_marginRight="15dp"
        android:src="@mipmap/btn_return_right"/>

      <com.jcodecraeer.xrecyclerview.XRecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tvLabelList"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

      <RelativeLayout
        android:id="@+id/ryEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tvLabelList"
        android:visibility="gone">

        <ImageView
          android:id="@+id/ivEmpty"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerInParent="true"
          android:background="@mipmap/rank_empty" />

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_centerHorizontal="true"
          android:layout_marginTop="25dp"
          android:layout_below="@+id/ivEmpty"
          android:text="@string/lbl_empty2"
          android:textColor="#ffffffff"
          android:textSize="15sp" />

      </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

  </androidx.core.widget.NestedScrollView>

  <TextView
    android:id="@+id/tvGotoClockIn"
    android:layout_width="226dp"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:layout_marginBottom="10dp"
    android:padding="11dp"
    android:background="@drawable/selector_match_btn_sign_up"
    android:gravity="center"
    android:textSize="14sp"
    android:textColor="#25282C"
    android:text="@string/btn_goto_clock_in"/>

</androidx.constraintlayout.widget.ConstraintLayout>