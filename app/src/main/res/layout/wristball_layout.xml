<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <androidx.fragment.app.FragmentContainerView
    android:id="@+id/layFragment"
    android:layout_weight="1"
    android:layout_width="match_parent"
    android:layout_height="0dp" />

  <LinearLayout
    android:id="@+id/rg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/bg_bottom_nav"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/rbRank"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:clickable="true"
      android:drawableTop="@mipmap/ic_tab_rank_2"
      android:gravity="center"
      android:text="@string/tab_rank"
      android:textAllCaps="false"
      android:textColor="@color/tabSelectedTextColor"
      android:textSize="14sp" />

    <TextView
      android:id="@+id/rbGo"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:clickable="true"
      android:drawableTop="@mipmap/ic_tab_go_2"
      android:gravity="center"
      android:text="@string/tab_go"
      android:textAllCaps="false"
      android:textColor="@color/tabSelectedTextColor"
      android:textSize="14sp" />

    <TextView
      android:id="@+id/rbMine"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:clickable="true"
      android:drawableTop="@mipmap/ic_tab_me_2"
      android:gravity="center"
      android:text="@string/tab_me"
      android:textAllCaps="false"
      android:textColor="@color/tabUnSelectedTextColor"
      android:textSize="14sp" />

  </LinearLayout>


</LinearLayout>