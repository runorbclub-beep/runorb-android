<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/layContent"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <RelativeLayout
    android:id="@+id/layTop"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="11dp"
    android:layout_marginBottom="14dp"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    app:layout_constraintTop_toTopOf="parent"
    android:gravity="center_vertical">

    <ImageView
      android:id="@+id/ivUserPortrait"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_centerVertical="true"
      android:background="@drawable/border_portrait"
      android:padding="1dp" />

    <LinearLayout
      android:id="@+id/layTodayDistanceSum"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_toRightOf="@+id/ivUserPortrait"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:paddingLeft="6dp"
      android:paddingRight="15dp"
      android:layout_centerVertical="true"
      android:orientation="vertical">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F7DC29"
        android:textSize="12sp"
        android:text="@string/tip_today_distance_sum"/>

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvTodayDistanceSum"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:drawablePadding="6dp"
          android:textColor="#F7DC29"
          android:textSize="19sp"
          android:textStyle="bold"
          tools:text="238.452"/>

        <TextView
          android:id="@+id/tvTodayDistanceUnit"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginLeft="4dp"
          android:drawableRight="@mipmap/ic_arrow_triangle_yellow"
          android:drawablePadding="6dp"
          android:textColor="#F7DC29"
          android:textSize="14sp"
          android:textStyle="bold"
          tools:text="km"/>

      </LinearLayout>

    </LinearLayout>

    <ImageView
      android:id="@+id/ivUpload"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_centerVertical="true"
      android:layout_marginRight="5dp"
      android:layout_toLeftOf="@+id/ivRule"
      android:src="@drawable/ic_sync" />

    <ImageView
      android:id="@+id/ivRule"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_alignParentRight="true"
      android:layout_centerVertical="true"
      android:src="@mipmap/icon_notice_tip" />

  </RelativeLayout>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/rvModuleList"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:layout_constraintTop_toBottomOf="@+id/layTop"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

  <TextView
    android:id="@+id/tvTip"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@+id/layTop"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:layout_marginLeft="37dp"
    android:layout_marginRight="37dp"
    android:background="@mipmap/bg_tip_record"
    android:paddingTop="7dp"
    android:textStyle="bold"
    android:gravity="center"
    android:textColor="#1E1D1F"
    android:textSize="14sp"
    android:visibility="gone"
    tools:visibility="visible"
    android:text="@string/tip_no_load_data"/>

</androidx.constraintlayout.widget.ConstraintLayout>