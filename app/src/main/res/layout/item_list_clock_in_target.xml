<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="horizontal">

  <LinearLayout
    android:layout_width="55dp"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
      android:id="@+id/tvMonth"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:textColor="#ADADAD"
      android:textSize="14sp"
      tools:text="11月"/>

    <TextView
      android:id="@+id/tvYear"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:textColor="#ADADAD"
      android:textSize="12sp"
      tools:text="2021年"/>

  </LinearLayout>

  <FrameLayout
    android:layout_width="wrap_content"
    android:layout_height="match_parent">

    <View
      android:id="@+id/vPointVLine"
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:background="@drawable/divider_horizontal"
      android:layout_gravity="center"
      android:layerType="software" />

    <ImageView
      android:id="@+id/ivSpot"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:src="@mipmap/spot_grey"/>

  </FrameLayout>

  <TextView
    android:id="@+id/layText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="25dp"
    android:layout_marginBottom="25dp"
    android:layout_marginLeft="40dp"
    android:gravity="center_vertical"
    android:textColor="#ADADAD"
    android:textSize="14sp"
    android:text="@string/btn_no_target"
    android:visibility="gone"/>

  <LinearLayout
    android:id="@+id/layAdd"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="25dp"
    android:layout_marginBottom="25dp"
    android:layout_marginLeft="40dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:visibility="gone">

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="#ADADAD"
      android:textSize="14sp"
      android:text="@string/btn_add_target"/>

    <ImageView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="6dp"
      android:src="@mipmap/add_gray"/>

  </LinearLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:layout_marginLeft="25dp"
    android:layout_marginRight="15dp"
    android:paddingTop="10dp"
    android:paddingBottom="13dp"
    android:paddingLeft="14dp"
    android:paddingRight="17dp"
    android:background="@drawable/bg_content_clock_in_target">

    <TextView
      android:id="@+id/tvTargetDatNum"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      android:gravity="center"
      android:textColor="#ADADAD"
      android:textSize="14sp"
      tools:text="目标20天"/>

    <TextView
      android:id="@+id/tvDatTargetDistance"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/tvTargetDatNum"
      app:layout_constraintBottom_toBottomOf="@+id/tvTargetDatNum"
      app:layout_constraintLeft_toRightOf="@+id/tvTargetDatNum"
      android:layout_marginLeft="9dp"
      android:gravity="center"
      android:textColor="#ADADAD"
      android:textSize="10sp"
      tools:text="每天20km"/>

    <ProgressBar
      android:id="@+id/progressBar"
      android:layout_width="117dp"
      android:layout_height="6dp"
      app:layout_constraintTop_toBottomOf="@+id/tvTargetDatNum"
      app:layout_constraintLeft_toLeftOf="parent"
      android:layout_marginTop="8dp"
      android:progressDrawable="@drawable/progress_drawable"
      style="@style/progressbar_close_in"/>

    <ImageView
      android:id="@+id/ivProgressSpot"
      android:layout_width="6dp"
      android:layout_height="6dp"
      app:layout_constraintTop_toTopOf="@+id/progressBar"
      app:layout_constraintLeft_toLeftOf="@+id/progressBar"
      app:layout_constraintBottom_toBottomOf="@+id/progressBar"
      android:src="@mipmap/spot_yellow"
      android:visibility="gone"
      tools:visibility="visible"/>

    <TextView
      android:id="@+id/tvCompleteDay"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintLeft_toRightOf="@+id/progressBar"
      app:layout_constraintTop_toTopOf="@+id/progressBar"
      app:layout_constraintBottom_toBottomOf="@+id/progressBar"
      android:layout_marginLeft="8dp"
      android:gravity="center"
      android:textColor="#ADADAD"
      android:textSize="12sp"
      tools:text="5/20"/>

    <TextView
      android:id="@+id/tvStatusInProgress"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/tvCompleteDay"
      app:layout_constraintBottom_toBottomOf="@+id/tvCompleteDay"
      app:layout_constraintLeft_toRightOf="@+id/tvCompleteDay"
      app:layout_constraintRight_toRightOf="parent"
      android:paddingLeft="11dp"
      android:paddingRight="11dp"
      android:layout_marginLeft="8dp"
      android:background="@drawable/bg_radius_666666"
      android:visibility="gone"
      tools:visibility="visible"
      android:gravity="center"
      android:textColor="#FFFFFF"
      android:textSize="12sp"
      tools:text="进行中"/>

    <ImageView
      android:id="@+id/tvStatusIsComplete"
      android:layout_width="26dp"
      android:layout_height="26dp"
      app:layout_constraintTop_toTopOf="@+id/tvCompleteDay"
      app:layout_constraintBottom_toBottomOf="@+id/tvCompleteDay"
      app:layout_constraintLeft_toRightOf="@+id/tvCompleteDay"
      app:layout_constraintRight_toRightOf="parent"
      android:visibility="gone"
      tools:background="@mipmap/info_checked"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>