<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="380sp"
        android:layout_gravity="center"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="50dp"
        android:layout_marginRight="20dp"
        android:background="@drawable/shape_sign_up_dialog"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/img_sign_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@mipmap/match_sign_up_success" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_dialog_reg_success"
            android:textColor="#ffffffff"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvHome"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:background="@drawable/shape_sign_up_btn"
            android:gravity="center"
            android:clickable="true"
            android:text="@string/lbl_dialog_return_home"
            android:textColor="#ffffffff"
            android:textSize="16sp" />
    </LinearLayout>


    <ImageView
        android:id="@+id/img_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:clickable="true"
        android:background="@mipmap/match_sign_up_close" />
</LinearLayout>