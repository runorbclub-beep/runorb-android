<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:background="@drawable/shape_func_item">


    <LinearLayout
        android:id="@+id/lyTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.219km"
            android:textColor="#fffde833"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvMaxSpeedTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:text="@string/lbl_speed_max"
            android:textColor="#ffffffff"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="21000"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@mipmap/corner_top_tip">
        <TextView
            android:id="@+id/tvGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:text="@string/lbl_match_corner_tip_2"
            android:textColor="#ffffff"
            android:textSize="@dimen/text_12" />
    </FrameLayout>



    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lyTop"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:text="2021.3.30 13:45"
        android:textColor="#ff767779"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnDetail"
        android:layout_width="90dp"
        android:layout_height="30dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="20dp"
        android:background="@drawable/selector_login_btn2"
        android:text="@string/lbl_detail2"
        android:textAllCaps="false"
        android:textSize="14sp" />

</RelativeLayout>
