<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimary"
    android:minHeight="?attr/actionBarSize"
    app:navigationIcon="@mipmap/btn_return">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="#FFFFFF"
      android:textSize="16sp"
      android:text="@string/title_page_clan_detail"/>

  </androidx.appcompat.widget.Toolbar>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="20dp"
    android:paddingBottom="30dp">

    <ImageView
      android:id="@+id/ivPortrait"
      android:layout_width="44dp"
      android:layout_height="44dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      android:layout_marginStart="20dp"
      android:padding="1dp"
      android:background="@drawable/border_radius_portrait"/>

    <TextView
      android:id="@+id/tvClanName"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/ivPortrait"
      app:layout_constraintBottom_toTopOf="@+id/tvMemberCount"
      app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
      android:layout_marginStart="10dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      tools:text="华为深圳分部团队"/>

    <TextView
      android:id="@+id/tvMemberCount"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@+id/tvClanName"
      app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
      app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
      android:layout_marginStart="10dp"
      android:paddingTop="1dp"
      android:paddingBottom="1dp"
      android:paddingStart="7dp"
      android:paddingEnd="7dp"
      android:background="@drawable/label_bg_text"
      android:textSize="11sp"
      android:textColor="#FFFFFF"
      tools:text="108个成员"/>

    <TextView
      android:id="@+id/tvArea"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@+id/tvClanName"
      app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
      app:layout_constraintLeft_toRightOf="@+id/tvMemberCount"
      android:layout_marginStart="6dp"
      app:drawableStartCompat="@mipmap/local_red"
      android:drawablePadding="2dp"
      android:textSize="11sp"
      android:textColor="#FFFFFF"
      tools:text="深圳" />

    <TextView
      android:id="@+id/tvOperation"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginEnd="15dp"
      android:paddingTop="3dp"
      android:paddingBottom="3dp"
      android:paddingStart="20dp"
      android:paddingEnd="20dp"
      android:background="@drawable/bg_btn_border_yellow_status"
      android:textColor="@drawable/text_btn_status_yellow"
      android:textSize="16sp"
      android:visibility="gone"
      tools:visibility="visible"
      tools:text="加入"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

  <net.lucode.hackware.magicindicator.MagicIndicator
    android:id="@+id/indicator"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    app:tabGravity="fill"
    app:tabMode="fixed"/>

  <androidx.viewpager2.widget.ViewPager2
    android:id="@+id/viewPager"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:orientation="horizontal"
    android:scrollbars="none" />

</LinearLayout>