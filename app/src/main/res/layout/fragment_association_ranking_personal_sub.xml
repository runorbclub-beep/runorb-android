<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  xmlns:tools="http://schemas.android.com/tools"
  android:background="@color/bg_content"
  android:orientation="vertical">

  <com.jcodecraeer.xrecyclerview.XRecyclerView
    android:id="@+id/recyclerview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/lyBottom"
    android:layout_gravity="center" />

  <RelativeLayout
    android:id="@+id/ryEmpty"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="150dp"
    android:visibility="gone">

    <ImageView
      android:id="@+id/ivEmpty"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:background="@mipmap/rank_empty" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerHorizontal="true"
      android:layout_marginTop="25dp"
      android:layout_below="@+id/ivEmpty"
      android:text="@string/lbl_empty2"
      android:textColor="#ffffffff"
      android:textSize="15sp" />

  </RelativeLayout>

  <LinearLayout
    android:id="@+id/lyBottom"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="true"
    android:background="#464A71"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:visibility="gone"
    tools:visibility="visible">

    <TextView
      android:id="@+id/tvRankNum"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="21dp"
      android:gravity="center_vertical"
      android:textColor="#fff9e85b"
      android:textSize="12sp"
      tools:text="101" />

    <ImageView
      android:id="@+id/ivHead"
      android:layout_width="50dp"
      android:layout_height="50dp"
      android:layout_gravity="center"
      android:layout_marginLeft="18dp"
      android:layout_marginRight="10dp"
      android:adjustViewBounds="true"
      tools:background="@mipmap/match_range_head_box" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2.5dp"
        android:orientation="horizontal"
        android:paddingRight="14dp">

        <TextView
          android:id="@+id/tvUserName"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:drawableLeft="@mipmap/ic_man"
          android:drawablePadding="5dp"
          android:gravity="center_vertical"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          tools:text="笑看人生" />

        <TextView
          android:id="@+id/tvUserSpeed"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:gravity="right"
          android:textColor="#F5BE0A"
          android:textSize="12sp"
          tools:text="342.33" />

        <TextView
          android:id="@+id/tvUnit"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:visibility="gone"
          tools:visibility="visible"
          android:textColor="#F5BE0A"
          android:textSize="10sp"
          tools:text="（rpm）" />


      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingRight="14dp">

        <TextView
          android:id="@+id/tvArea"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:drawableLeft="@mipmap/local_red"
          android:textColor="#C7C7C7"
          android:textSize="9sp"
          tools:text="深圳" />

        <View
          android:id="@+id/vDivider"
          android:layout_width="1dp"
          android:layout_height="match_parent"
          android:layout_marginTop="1dp"
          android:layout_marginBottom="1dp"
          android:layout_marginLeft="10dp"
          android:layout_marginRight="10dp"
          android:background="#C7C7C7"/>

        <TextView
          android:id="@+id/tvRankTime"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#C7C7C7"
          android:textSize="9sp"
          tools:text="2021-6-1 17:55:34" />

      </LinearLayout>

    </LinearLayout>

  </LinearLayout>

</RelativeLayout>