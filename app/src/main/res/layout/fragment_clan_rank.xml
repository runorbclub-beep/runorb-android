<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <com.jcodecraeer.xrecyclerview.XRecyclerView
    android:id="@+id/recyclerview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/layBottom"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

  <RelativeLayout
    android:id="@+id/ryEmpty"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/layBottom"
    android:visibility="gone"
    tools:visibility="visible">

    <ImageView
      android:id="@+id/ivEmpty"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:background="@mipmap/rank_empty" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_below="@+id/ivEmpty"
      android:layout_centerHorizontal="true"
      android:layout_marginTop="25dp"
      android:text="@string/lbl_empty2"
      android:textColor="#ffffffff"
      android:textSize="15sp" />

  </RelativeLayout>

  <FrameLayout
    android:id="@+id/layBottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true">

    <LinearLayout
      android:id="@+id/lyBottom"
      android:layout_width="match_parent"
      android:layout_height="60dp"
      android:layout_alignParentBottom="true"
      android:background="#464A71"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:visibility="gone"
      tools:visibility="visible">

      <TextView
        android:id="@+id/tvRankNum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="21dp"
        android:gravity="center_vertical"
        android:textColor="#fff9e85b"
        android:textSize="12sp"
        tools:text="101" />

      <ImageView
        android:id="@+id/ivHead"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_marginLeft="18dp"
        android:layout_marginRight="10dp"
        android:adjustViewBounds="true"
        android:padding="1dp"
        android:background="@drawable/border_rectangle_portrait" />

      <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
          android:id="@+id/tvClanName"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintBottom_toTopOf="@+id/tvArea"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toStartOf="@+id/tvValue"
          app:layout_constrainedWidth="true"
          app:layout_constraintHorizontal_bias="0"
          android:singleLine="true"
          app:drawableRightCompat="@mipmap/ic_man"
          android:drawablePadding="5dp"
          android:gravity="center_vertical"
          android:textColor="#FFFFFF"
          android:textSize="13sp"
          tools:text="笑看人生" />

        <TextView
          android:id="@+id/tvArea"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/tvClanName"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:drawableLeftCompat="@mipmap/local_red"
          android:textColor="#C7C7C7"
          android:textSize="9sp"
          tools:text="深圳" />

        <View
          android:id="@+id/vDivider"
          android:layout_width="1dp"
          android:layout_height="10dp"
          app:layout_constraintTop_toTopOf="@+id/tvArea"
          app:layout_constraintBottom_toBottomOf="@+id/tvArea"
          app:layout_constraintStart_toEndOf="@+id/tvArea"
          android:layout_marginStart="10dp"
          android:background="#C7C7C7" />

        <TextView
          android:id="@+id/tvMemberCount"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/tvArea"
          app:layout_constraintBottom_toBottomOf="@+id/tvArea"
          app:layout_constraintStart_toEndOf="@+id/vDivider"
          android:layout_marginStart="10dp"
          android:textColor="#C7C7C7"
          android:textSize="9sp"
          tools:text="成员数 11人" />

        <TextView
          android:id="@+id/tvValue"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toStartOf="@+id/tvUnit"
          android:textColor="#F5BE0A"
          android:textSize="12sp"
          tools:text="342.33" />

        <TextView
          android:id="@+id/tvUnit"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toStartOf="@+id/ivMore"
          android:visibility="gone"
          tools:visibility="visible"
          android:textColor="#F5BE0A"
          android:textSize="10sp"
          tools:text="（rpm）" />

        <ImageView
          android:id="@+id/ivMore"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          android:layout_marginEnd="15dp"
          android:src="@mipmap/item_more"/>

        <androidx.constraintlayout.widget.Group
          android:id="@+id/groupPass"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:visibility="gone"
          app:constraint_referenced_ids="tvValue,tvUnit,ivMore" />

        <TextView
          android:id="@+id/tvPendingState"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          android:layout_marginEnd="40dp"
          android:paddingTop="2dp"
          android:paddingBottom="2dp"
          android:paddingStart="11dp"
          android:paddingEnd="11dp"
          android:background="@drawable/label_bg_text_2"
          android:textColor="#1E1D1F"
          android:textSize="14sp"
          android:text="@string/state_will_pending"
          android:visibility="gone"
          tools:visibility="visible"/>

      </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/layBottomTools"
      android:layout_width="match_parent"
      android:layout_height="60dp"
      android:visibility="gone"
      tools:visibility="gone">

      <TextView
        android:id="@+id/tvCreateClan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent="0.53"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:background="@mipmap/btn_clan_left"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:text="@string/clan_create"/>

      <TextView
        android:id="@+id/tvJoinClan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent="0.53"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="@mipmap/btn_clan_right"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:text="@string/clan_join"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

  </FrameLayout>

</RelativeLayout>