<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#1E1D1F"
  android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimary"
    android:minHeight="?attr/actionBarSize"
    app:navigationIcon="@mipmap/btn_return">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="#FFFFFF"
      android:textSize="16sp"
      android:text="@string/title_data_detail"/>

    <ImageView
      android:id="@+id/ivShareEntry"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:layout_marginRight="15dp"
      android:src="@drawable/ic_tijiao"/>

  </androidx.appcompat.widget.Toolbar>

  <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    android:id="@+id/layRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
      android:layout_width="match_parent"
      android:layout_height="match_parent">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:orientation="vertical">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

          <TextView
            android:id="@+id/tvCreateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F7DC29"
            android:textSize="14sp"
            tools:text="12/16 16:39:20"/>

          <TextView
            android:id="@+id/tvSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="14sp"
            tools:text="（来源：摇加油）"/>

        </LinearLayout>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="15dp"
          android:paddingTop="50dp"
          android:paddingBottom="40dp"
          android:background="@drawable/bg_mine_data_area"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
              android:id="@+id/layMaxSpeed"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:visibility="gone"
              tools:visibility="visible"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvMaxSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_speed_3"/>

            </LinearLayout>

            <LinearLayout
              android:id="@+id/layOneMinute"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:visibility="gone"
              tools:visibility="visible"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvOneMinute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_one_minute_3"/>

            </LinearLayout>

            <LinearLayout
              android:id="@+id/layExponent"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:visibility="gone"
              tools:visibility="visible"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvExponent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_exponent_2"/>

            </LinearLayout>

            <LinearLayout
              android:id="@+id/layMarathon"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:visibility="gone"
              tools:visibility="visible"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvMarathon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_marathon_2"/>

            </LinearLayout>

          </LinearLayout>

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="37dp"
            android:orientation="horizontal">

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvTurnDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_duration"/>

            </LinearLayout>

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:gravity="center"
              android:orientation="vertical">

              <TextView
                android:id="@+id/tvTurnMetre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F7DC29"
                android:textSize="18sp"
                tools:text="13021"/>

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"
                android:text="@string/turn_metre"/>

            </LinearLayout>

          </LinearLayout>

        </LinearLayout>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:padding="25dp"
          android:layout_marginTop="15dp"
          android:background="@drawable/bg_mine_data_area"
          android:orientation="vertical">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:textSize="14sp"
              android:textColor="#FFFFFF"
              android:text="@string/lbl_speed_between"/>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textSize="14sp"
              android:textColor="#FFFFFF"
              android:text="@string/lbl_speed_time"/>

          </LinearLayout>

          <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSpeedBetweenList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        </LinearLayout>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="15dp"
          android:padding="25dp"
          android:layout_marginTop="15dp"
          android:background="@drawable/bg_mine_data_area"
          android:orientation="vertical">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:text="@string/lbl_speed_chart"/>

          <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/speedChart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="10dp"/>

        </LinearLayout>

        <LinearLayout
          android:id="@+id/layMessage"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="24dp"
          android:paddingTop="12dp"
          android:paddingBottom="12dp"
          android:paddingLeft="10dp"
          android:paddingRight="10dp"
          android:background="@drawable/bg_mine_data_area"
          android:visibility="gone"
          tools:visibility="visible"
          android:orientation="horizontal">

          <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@mipmap/error_wain"
            android:drawablePadding="8dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="@string/data_error_speed"/>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
          android:id="@+id/layOperation"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="24dp"
          android:visibility="gone"
          tools:visibility="visible"
          android:orientation="horizontal">

          <TextView
            android:id="@+id/tvDelete"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/tvUpload"
            android:padding="11dp"
            android:background="@drawable/selector_score_date_title"
            android:textSize="14sp"
            android:textColor="#F7DC29"
            android:gravity="center"
            android:text="@string/delete"/>

          <TextView
            android:id="@+id/tvUpload"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/tvDelete"
            app:layout_constraintRight_toRightOf="parent"
            android:padding="11dp"
            android:background="@drawable/selector_match_btn_sign_up"
            android:textSize="14sp"
            android:textColor="#1E1D1F"
            android:gravity="center"
            android:text="@string/btn_upload"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

      </LinearLayout>

    </androidx.core.widget.NestedScrollView>

  </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>