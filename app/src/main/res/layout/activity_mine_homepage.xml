<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layHeader"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:layout_constraintDimensionRatio="w,7:10"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@mipmap/page_bg_top">

    <androidx.appcompat.widget.Toolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      android:minHeight="?attr/actionBarSize"
      app:navigationIcon="@mipmap/btn_return"/>

    <ImageView
      android:id="@+id/img_info_avatar"
      android:layout_width="52dp"
      android:layout_height="52dp"
      android:padding="1dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintVertical_bias="0.4"
      android:layout_marginLeft="16dp"
      android:adjustViewBounds="true"
      android:scaleType="centerCrop"
      android:background="@drawable/border_ranking_portrait_top" />

    <ImageView
      android:id="@+id/ivVip"
      android:layout_width="22dp"
      android:layout_height="22dp"
      app:layout_constraintTop_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintRight_toRightOf="@+id/img_info_avatar"
      android:visibility="gone"
      tools:visibility="visible"
      android:background="@mipmap/tag_vip" />

    <TextView
      android:id="@+id/tv_info_nickname"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      app:layout_constraintTop_toTopOf="@+id/img_info_avatar"
      app:layout_constraintBottom_toTopOf="@+id/tvArea"
      app:layout_constraintLeft_toRightOf="@+id/img_info_avatar"
      android:drawablePadding="2dp"
      android:gravity="center_vertical"
      android:textColor="#ffffffff"
      android:textSize="16sp"
      tools:drawableLeft="@mipmap/ic_man"
      tools:text="@string/lbl_default_name" />

    <TextView
      android:id="@+id/tvAge"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      app:layout_constraintTop_toTopOf="@+id/tv_info_nickname"
      app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintLeft_toRightOf="@+id/img_info_avatar"
      android:singleLine="true"
      android:textColor="#DDDDDD"
      android:textSize="12sp"
      tools:text="10岁" />

    <View
      android:id="@+id/areaDivide"
      android:layout_width="1dp"
      android:layout_height="11dp"
      app:layout_constraintTop_toTopOf="@+id/tvAge"
      app:layout_constraintBottom_toBottomOf="@+id/tvAge"
      app:layout_constraintLeft_toRightOf="@+id/tvAge"
      android:layout_marginLeft="7dp"
      android:background="#DDDDDD"/>

    <TextView
      android:id="@+id/tvArea"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      app:layout_constraintTop_toTopOf="@+id/tv_info_nickname"
      app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintLeft_toRightOf="@+id/tvAge"
      android:singleLine="true"
      android:textColor="#DDDDDD"
      android:textSize="12sp"
      tools:text="深圳" />

    <View
      android:id="@+id/weixinDivide"
      android:layout_width="1dp"
      android:layout_height="11dp"
      app:layout_constraintTop_toTopOf="@+id/tvWeixin"
      app:layout_constraintBottom_toBottomOf="@+id/tvWeixin"
      app:layout_constraintRight_toLeftOf="@+id/tvWeixin"
      android:layout_marginRight="7dp"
      android:background="#DDDDDD"/>

    <TextView
      android:id="@+id/tvWeixin"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      app:layout_constraintTop_toTopOf="@+id/tv_info_nickname"
      app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintLeft_toRightOf="@+id/tvArea"
      android:singleLine="true"
      android:textColor="#DDDDDD"
      android:textSize="12sp"
      tools:text="微信号:Y323787834" />

    <TextView
      android:id="@+id/tv_info_sign"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:layout_marginLeft="20dp"
      android:layout_marginRight="20dp"
      app:layout_constraintWidth="match_parent"
      app:layout_constraintTop_toBottomOf="@+id/img_info_avatar"
      app:layout_constraintLeft_toLeftOf="parent"
      android:singleLine="true"
      android:textColor="#ff767779"
      android:textSize="12sp"
      tools:text="@string/lbl_default_sign" />

    <ImageView
      android:id="@+id/ivBgScore"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintVertical_bias="0.4"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      android:background="@mipmap/bg_accumulate_points"/>

    <LinearLayout
      android:id="@+id/layScore"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/ivBgScore"
      app:layout_constraintBottom_toBottomOf="parent"
      android:layout_marginLeft="15dp"
      android:layout_marginRight="15dp"
      android:gravity="center"
      android:paddingLeft="20dp"
      android:paddingTop="18dp"
      android:paddingRight="20dp"
      android:paddingBottom="18dp"
      android:orientation="horizontal">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#28272A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:text="@string/turn_exponent_2"/>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#28272A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:text="(ei):"/>

      <TextView
        android:id="@+id/tvExponent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:textColor="#28272A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:text="0" />

    </LinearLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>

  <LinearLayout
    android:id="@+id/layAchievement"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@+id/layHeader"
    android:paddingTop="36dp"
    android:paddingBottom="36dp"
    android:showDividers="middle"
    android:divider="@drawable/divider_horizontal"
    android:background="#28272A"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ADADAD"
        android:textSize="12sp"
        android:text="@string/turn_speed_2"/>
      <TextView
        android:id="@+id/tvMaxSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#FDE833"
        android:text="0"/>
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="10sp"
        android:text="@string/turn_speed_unit_2"/>
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ADADAD"
        android:textSize="12sp"
        android:text="@string/turn_one_minute_2"/>
      <TextView
        android:id="@+id/tvOneMinute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#FDE833"
        android:text="0"/>
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="10sp"
        android:text="@string/turn_one_minute_unit_2"/>
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ADADAD"
        android:textSize="12sp"
        android:text="@string/turn_marathon_2"/>
      <TextView
        android:id="@+id/tvMarathon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#FDE833"
        android:text="0"/>
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="10sp"
        android:text="@string/turn_marathon_unit_2"/>
    </LinearLayout>

  </LinearLayout>

  <androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    app:layout_constraintTop_toBottomOf="@+id/layAchievement"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constrainedHeight="true"
    app:layout_constraintVertical_bias="0">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical">

      <LinearLayout
        android:id="@+id/layClan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginLeft="15dp"
          android:textColor="#FFFFFF"
          android:textSize="14sp"
          android:text="@string/label_clan_mine"/>

        <androidx.constraintlayout.widget.ConstraintLayout
          android:id="@+id/layClanInfo"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp"
          android:layout_marginLeft="15dp"
          android:background="#28272A"
          android:orientation="vertical">

          <ImageView
            android:id="@+id/ivHead"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="@null"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:background="@drawable/border_rectangle_portrait_top" />

          <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tvClanArea"
            app:layout_constraintStart_toEndOf="@+id/ivHead"
            app:layout_constrainedWidth="true"
            app:layout_constraintHorizontal_bias="0"
            android:singleLine="true"
            android:layout_marginStart="10dp"
            android:drawablePadding="4dp"
            android:gravity="center_vertical"
            android:textColor="#ffffffff"
            android:textSize="13sp"
            tools:text="笑对人生" />

          <TextView
            android:id="@+id/tvClanArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/tvName"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivHead"
            app:drawableLeftCompat="@mipmap/local_red"
            android:layout_marginStart="10dp"
            android:textColor="#C7C7C7"
            android:textSize="9sp"
            tools:text="深圳" />

          <View
            android:id="@+id/vDivider"
            android:layout_width="1dp"
            android:layout_height="10dp"
            app:layout_constraintTop_toTopOf="@+id/tvClanArea"
            app:layout_constraintBottom_toBottomOf="@+id/tvClanArea"
            app:layout_constraintStart_toEndOf="@+id/tvClanArea"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="1dp"
            android:layout_marginStart="10dp"
            android:background="#C7C7C7"/>

          <TextView
            android:id="@+id/tvMemberCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@+id/tvClanArea"
            app:layout_constraintBottom_toBottomOf="@+id/tvClanArea"
            app:layout_constraintStart_toEndOf="@+id/vDivider"
            android:layout_marginStart="10dp"
            android:textColor="#C7C7C7"
            android:textSize="9sp"
            tools:text="成员数 11人" />

          <ImageView
            android:id="@+id/ivMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginRight="10dp"
            android:src="@mipmap/item_more"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

      </LinearLayout>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="15dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:text="@string/label_clan_dynamic"/>

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_gravity="center"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    </LinearLayout>

  </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>