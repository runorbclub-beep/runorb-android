<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  xmlns:tools="http://schemas.android.com/tools"
  android:background="@color/bg_content"
  android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:layout_gravity="center"
    android:background="?attr/colorPrimary"
    android:minHeight="?attr/actionBarSize"
    android:theme="?attr/actionBarTheme"
    android:gravity="center_vertical"
    app:navigationIcon="@mipmap/btn_return">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="@android:color/white"
      android:textSize="16sp"
      android:text="@string/title_runOrb_match"/>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/ivShareEntry"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginRight="5dp"
        android:layout_toLeftOf="@+id/ivUpload"
        android:src="@drawable/ic_tijiao" />

      <ImageView
        android:id="@+id/ivStop"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginRight="5dp"
        android:layout_toLeftOf="@+id/ivUpload"
        android:src="@drawable/ic_stop" />

    </LinearLayout>

  </androidx.appcompat.widget.Toolbar>

  <TextView
    android:id="@+id/tvMatchName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:textColor="#F9E85B"
    android:textSize="11sp"
    tools:text="(aaaaa)"/>

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:layout_gravity="center"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/tvDay"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:minWidth="37dp"
      android:minHeight="37dp"
      android:background="@drawable/bg_item_time"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center"
      android:textColor="#FDE833"
      android:textSize="21sp"
      tools:text="03"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="2dp"
      android:layout_marginRight="2dp"
      android:gravity="center"
      android:textSize="15sp"
      android:textColor="#999999"
      android:text="天"/>

    <TextView
      android:id="@+id/tvHour"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:minWidth="37dp"
      android:minHeight="37dp"
      android:background="@drawable/bg_item_time"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center"
      android:textColor="#FDE833"
      android:textSize="21sp"
      tools:text="03"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="2dp"
      android:layout_marginRight="2dp"
      android:gravity="center"
      android:textSize="15sp"
      android:textColor="#999999"
      android:text=":"/>

    <TextView
      android:id="@+id/tvMinute"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:minWidth="37dp"
      android:minHeight="37dp"
      android:background="@drawable/bg_item_time"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center"
      android:textColor="#FDE833"
      android:textSize="21sp"
      tools:text="03"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="2dp"
      android:layout_marginRight="2dp"
      android:gravity="center"
      android:textSize="15sp"
      android:textColor="#999999"
      android:text=":"/>

    <TextView
      android:id="@+id/tvSecond"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:minWidth="37dp"
      android:minHeight="37dp"
      android:background="@drawable/bg_item_time"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center"
      android:textColor="#FDE833"
      android:textSize="21sp"
      tools:text="03"/>

  </LinearLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constrainedWidth="true"
      app:layout_constraintDimensionRatio="h,1:1"
      android:adjustViewBounds="true"
      android:layout_gravity="center"
      android:background="@mipmap/canvas_circle_bg">

    </FrameLayout>

    <com.cloud.runball.widget.MagicTextView2
      android:id="@+id/tvSpeedRPMFormat"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constrainedWidth="true"
      app:layout_constrainedHeight="true"
      app:layout_constraintHeight_percent="0.7"
      app:layout_constraintDimensionRatio="h,1:1"
      android:layout_gravity="center"
      android:gravity="center"
      android:textColor="#fff7b2"
      android:textSize="26sp"
      android:textStyle="bold"
      app:animTime="@integer/animation_duration"
      android:text="0"/>

    <com.littlejie.circleprogress.CircleProgress
      android:id="@+id/circle_progress_bar"
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_gravity="center"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constrainedWidth="true"
      app:layout_constrainedHeight="true"
      app:layout_constraintHeight_percent="0.7"
      app:layout_constraintDimensionRatio="h,1:1"
      app:animTime="@integer/animation_duration"
      app:antiAlias="true"
      app:arcColors="@array/gradient_arc_color"
      app:arcWidth="@dimen/medium"
      app:bgArcColor="@color/circle_bg"
      app:bgArcWidth="@dimen/large"
      app:hint=""
      app:hintColor="#fff7b2"
      app:hintSize="@dimen/text_size_15"
      app:maxValue="100"
      app:startAngle="150"
      app:sweepAngle="240"
      app:textOffsetPercentInRadius="0.5"
      app:unit=""
      app:unitColor="#fff7b2"
      app:unitSize="@dimen/text_size_15"
      app:value="0"
      app:valueColor="#00fff7b2"
      app:valueSize="@dimen/text_size_64"/>

    <com.cloud.runball.widget.PointerImageView
      android:id="@+id/ivPointer"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constrainedWidth="true"
      app:layout_constrainedHeight="true"
      app:layout_constraintHeight_percent="0.4"
      app:layout_constraintDimensionRatio="h,1:1"
      android:layout_gravity="center"
      android:adjustViewBounds="true"
      android:background="@mipmap/canvas_circle_pointer"
      android:rotation="0.0"
      android:scaleType="fitCenter"
      app:animTime="@integer/animation_duration" />

    <com.cloud.runball.widget.SpeedCircleImageView
      android:id="@+id/ivSpeedCircle"
      android:layout_width="0dp"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constrainedWidth="true"
      app:layout_constrainedHeight="true"
      app:layout_constraintHeight_percent="0.8"
      app:layout_constraintDimensionRatio="h,1:1"
      android:layout_gravity="center"
      android:adjustViewBounds="true"
      android:background="@mipmap/canvas_circle"
      android:scaleType="fitCenter"
      app:animTime="@integer/animation_duration" />

  </androidx.constraintlayout.widget.ConstraintLayout>

  <LinearLayout
    android:id="@+id/layNotice"
    android:layout_width="match_parent"
    android:layout_height="35dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:background="@drawable/tip_corner_bg"
    android:orientation="horizontal"
    android:visibility="invisible"
    tools:visibility="visible">

    <ImageView
      android:id="@+id/ivNoticeSwitch"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:src="@mipmap/icon_notice"/>

    <TextView
      android:id="@+id/tvNoticeTip"
      android:layout_width="match_parent"
      android:layout_height="35dp"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="6dp"
      android:ellipsize="marquee"
      android:singleLine="true"
      android:gravity="center_vertical"
      android:textColor="#FFFFFF"
      android:textSize="14sp"
      tools:text="摇跑马拉松，1小时13分钟46秒"/>

  </LinearLayout>

  <com.cloud.runball.widget.PlayingProgressView
    android:id="@+id/playingProgressView"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:padding="20dp"
    app:bar_bg_color="#666666"
    app:bar_progress_color_start="#FFE733"
    app:bar_progress_color_end="#EF4F08"
    app:bar_height="5dp"
    app:bar_text_color="#999999"
    app:bar_start_text="@string/start"
    app:bar_start_text_padding="6dp"
    app:bar_text_size="11sp"
    app:node_size="11dp"
    app:node_color_light="#FDE833"
    app:node_color_dark="#666666"
    app:node_text_padding="8dp"
    app:node_arrive_text_color="#FFFFFF"
    app:node_arrive_text_size="12sp"
    app:progress_init="0"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="101dp"
      android:layout_marginLeft="10dp"
      android:layout_marginRight="10dp"
      android:background="@mipmap/race_circle_box"
      android:gravity="center_horizontal"
      android:orientation="horizontal"
      android:paddingLeft="60dp"
      android:paddingRight="60dp"
      android:paddingBottom="10dp">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:text="@string/turn_speed"
          android:textColor="#ff838383"
          android:textSize="12sp" />

        <TextView
          android:id="@+id/tvTurnHeightSpeedRPM"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="18sp"
          android:text="0" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:text="@string/turn_metre"
          android:textColor="#ff838383"
          android:textSize="12sp" />

        <TextView
          android:id="@+id/tvTurnDistance"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1.0"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="18sp"
          android:text="0.000" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:text="@string/turn_time"
          android:textColor="#ff838383"
          android:textSize="12sp" />

        <TextView
          android:id="@+id/tvTurnTime"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1.0"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="18sp"
          android:text="00:00" />

      </LinearLayout>

    </LinearLayout>

    <include
      android:id="@+id/lyAction"
      layout="@layout/layout_ble_tip"
      android:layout_width="match_parent"
      android:layout_height="40dp"
      android:layout_marginTop="15dp" />

  </LinearLayout>

</LinearLayout>