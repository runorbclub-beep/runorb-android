<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@mipmap/badge_bg">

    <ImageView
        android:id="@+id/ivClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="10dp"
        android:background="@mipmap/btn_close"
        android:clickable="true"
        android:adjustViewBounds="true"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">


        <ImageView
            android:id="@+id/ivBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:src="@mipmap/badge_desc_1"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvBadgeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:text="@string/lbl_badge_tip"
            android:textColor="#ffffffff"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tvBadgeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="@string/lbl_badge_circle_tip"
            android:textColor="#ff767779"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="100dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginLeft="20dp"
                android:layout_weight="1.0"
                android:visibility="invisible"
                android:background="@color/line" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1.0"
                android:gravity="center"
                android:text="@string/lbl_badge_dese_tip"
                android:visibility="gone"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginRight="20dp"
                android:layout_weight="1.0"
                android:visibility="invisible"
                android:background="@color/line" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_douyin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="50dp"
                android:layout_weight="1.0"
                android:drawableTop="@mipmap/icon_share_douyin"
                android:drawablePadding="5dp"
                android:gravity="center"
                android:text="@string/lbl_douyin"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_qq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1.0"
                android:drawableTop="@mipmap/icon_share_qq"
                android:drawablePadding="5dp"
                android:gravity="center"
                android:text="@string/lbl_qq"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_qqzone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginRight="50dp"
                android:layout_weight="1.0"
                android:drawableTop="@mipmap/icon_share_qqzone"
                android:drawablePadding="5dp"
                android:gravity="center"
                android:text="@string/lbl_share_qqzone"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:visibility="gone"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_wechat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="10dp"
                android:layout_weight="1.0"
                android:drawableTop="@mipmap/icon_share_wechat"
                android:drawablePadding="5dp"
                android:gravity="center"
                android:text="@string/lbl_wechat"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_wechat_circle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="50dp"
                android:layout_weight="1.0"
                android:drawableTop="@mipmap/icon_share_wechat_circle"
                android:drawablePadding="5dp"
                android:gravity="center"
                android:text="@string/lbl_share_wechat_circle"
                android:textColor="#ffc2c2c3"
                android:textSize="14sp" />

        </LinearLayout>


    </LinearLayout>

</RelativeLayout>