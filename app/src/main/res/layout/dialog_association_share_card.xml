<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:background="#25000000">

  <androidx.core.widget.NestedScrollView
    android:id="@+id/lyScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_gravity="center_horizontal"
      android:orientation="vertical">

      <ImageView
        android:id="@+id/ivClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_gravity="right"
        android:src="@mipmap/close_yellow"/>

      <!--      <ImageView-->
<!--        android:id="@+id/ivClose"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginTop="10dp"-->
<!--        android:layout_marginRight="20dp"-->
<!--        android:layout_gravity="right"-->
<!--        android:src="@mipmap/close_yellow"/>-->

      <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lyContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:paddingBottom="33dp"
        android:background="@mipmap/bg_share_card"
        android:layout_gravity="center">

        <TextView
          android:id="@+id/tvCardTitle"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="23dp"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          android:gravity="center"
          android:textColor="#FFFFFF"
          android:textSize="16sp"
          tools:text="2021年足球联赛摇跑运动"/>

        <ImageView
          android:id="@+id/ivPortrait"
          android:layout_width="55dp"
          android:layout_height="55dp"
          app:layout_constraintTop_toBottomOf="@+id/tvCardTitle"
          app:layout_constraintLeft_toLeftOf="parent"
          android:layout_marginTop="37dp"
          android:layout_marginLeft="20dp"
          android:background="@drawable/border_portrait"/>

        <TextView
          android:id="@+id/tvUserName"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/ivPortrait"
          app:layout_constraintBottom_toTopOf="@+id/tvArea"
          app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
          android:layout_marginLeft="8dp"
          android:gravity="center"
          android:textColor="#ffffff"
          android:textSize="14sp"
          tools:text="aaaa"/>

        <TextView
          android:id="@+id/tvArea"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/tvUserName"
          app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
          app:layout_constraintLeft_toRightOf="@+id/ivPortrait"
          android:layout_marginLeft="5dp"
          android:drawableLeft="@mipmap/icon_pos"
          android:gravity="center"
          android:textColor="#F9E85B"
          android:textSize="12sp"
          tools:text="广东 深圳"/>

        <FrameLayout
          android:id="@+id/layQrCode"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/ivPortrait"
          app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
          app:layout_constraintRight_toLeftOf="@+id/tvQrCodeTip"
          android:layout_marginRight="3dp"
          android:padding="3dp"
          android:background="@mipmap/bg_qr_code">

          <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="74dp"
            android:layout_height="74dp"
            tools:background="#666666"/>

        </FrameLayout>

        <TextView
          android:id="@+id/tvQrCodeTip"
          android:layout_width="12dp"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toTopOf="@+id/ivPortrait"
          app:layout_constraintBottom_toBottomOf="@+id/ivPortrait"
          app:layout_constraintRight_toRightOf="parent"
          android:lineHeight="10dp"
          android:layout_marginRight="23dp"
          android:textColor="#F9E85B"
          android:textSize="10sp"
          android:text="@string/share_qr_code_tip"/>

        <LinearLayout
          android:id="@+id/layAchievement"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center_horizontal"
          app:layout_constraintTop_toBottomOf="@+id/layQrCode"
          android:layout_marginTop="46dp"
          android:layout_marginLeft="20dp"
          android:layout_marginRight="20dp"
          android:paddingTop="20dp"
          android:paddingBottom="32dp"
          android:paddingLeft="40dp"
          android:paddingRight="40dp"
          android:background="@drawable/bg_share_data"
          android:orientation="vertical">

          <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="13.5dp"
            android:textColor="#F9E85B"
            android:textSize="18sp"
            tools:text="2021-11-23"/>

          <TextView
            android:id="@+id/tvMaxRpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginTop="4.5dp"
            android:layout_marginBottom="4.5dp"
            android:background="@mipmap/bg_data_item"
            android:gravity="center_vertical"
            android:textColor="#ffffff"
            android:textSize="12sp"
            tools:text="最高转速：21323(rpm)"/>

          <TextView
            android:id="@+id/tvDataMinute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginTop="4.5dp"
            android:layout_marginBottom="4.5dp"
            android:background="@mipmap/bg_data_item"
            android:gravity="center_vertical"
            android:textColor="#ffffff"
            android:textSize="12sp"
            tools:text="摇跑1分钟：1km"/>

          <TextView
            android:id="@+id/tvExponent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginTop="4.5dp"
            android:layout_marginBottom="4.5dp"
            android:background="@mipmap/bg_data_item"
            android:gravity="center_vertical"
            android:textColor="#ffffff"
            android:textSize="12sp"
            tools:text="活力指数：100"/>

<!--          <TextView-->
<!--            android:id="@+id/tvHalfMarathon"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:paddingLeft="20dp"-->
<!--            android:paddingRight="20dp"-->
<!--            android:layout_marginTop="4.5dp"-->
<!--            android:layout_marginBottom="4.5dp"-->
<!--            android:background="@mipmap/bg_data_item"-->
<!--            android:gravity="center_vertical"-->
<!--            android:textColor="#ffffff"-->
<!--            android:textSize="12sp"-->
<!--            tools:text="半马用时：01:30:30"/>-->

          <TextView
            android:id="@+id/tvMarathon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:layout_marginTop="4.5dp"
            android:layout_marginBottom="4.5dp"
            android:background="@mipmap/bg_data_item"
            android:gravity="center_vertical"
            android:textColor="#ffffff"
            android:textSize="12sp"
            tools:text="全马用时：01:30:30"/>

        </LinearLayout>

        <LinearLayout
          android:id="@+id/layData"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          app:layout_constraintTop_toBottomOf="@+id/layAchievement"
          android:layout_marginTop="20dp"
          android:layout_marginLeft="20dp"
          android:layout_marginRight="20dp"
          android:paddingLeft="25dp"
          android:paddingRight="25dp"
          android:background="@mipmap/race_circle_box"
          android:orientation="horizontal">

          <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_centerHorizontal="true"
              android:gravity="center"
              android:text="@string/turn_metre"
              android:textColor="#ffffff"
              android:textSize="10sp" />

            <TextView
              android:id="@+id/tvDistance"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_centerInParent="true"
              android:gravity="center"
              android:textColor="#ffffff"
              android:textSize="18sp"
              tools:text="4.219" />

          </RelativeLayout>

          <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_centerHorizontal="true"
              android:gravity="center"
              android:text="@string/turn_time"
              android:textColor="#ffffff"
              android:textSize="10sp" />

            <TextView
              android:id="@+id/tvCostTime"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:gravity="center"
              android:layout_centerInParent="true"
              android:textColor="#ffffff"
              android:textSize="18sp"
              tools:text="03:00"/>

          </RelativeLayout>

        </LinearLayout>

      </androidx.constraintlayout.widget.ConstraintLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvShare"
          android:layout_width="120dp"
          android:layout_height="wrap_content"
          android:layout_marginRight="15dp"
          android:paddingTop="10dp"
          android:paddingBottom="10dp"
          android:paddingLeft="24dp"
          android:paddingRight="24dp"
          android:background="@drawable/btn_other"
          android:gravity="center"
          android:textSize="15sp"
          android:textColor="#F5BE0A"
          android:textStyle="bold"
          android:text="@string/lbl_share_btn"/>

        <TextView
          android:id="@+id/tvMore"
          android:layout_width="120dp"
          android:layout_height="wrap_content"
          android:layout_marginLeft="15dp"
          android:paddingTop="10dp"
          android:paddingBottom="10dp"
          android:paddingLeft="24dp"
          android:paddingRight="24dp"
          android:background="@drawable/btn_share"
          android:gravity="center"
          android:textSize="15sp"
          android:textColor="#1A1D20"
          android:textStyle="bold"
          android:text="@string/btn_once_more"/>

      </LinearLayout>

    </LinearLayout>

  </androidx.core.widget.NestedScrollView>

</FrameLayout>
