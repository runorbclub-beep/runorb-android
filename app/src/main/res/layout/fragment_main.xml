<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#1E1D1F"
  android:orientation="vertical">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:minHeight="?attr/actionBarSize"
    android:theme="?attr/actionBarTheme"
    android:gravity="center_vertical"
    app:navigationIcon="@mipmap/btn_return">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="@android:color/white"
      android:textSize="16sp"
      android:text="@string/title_go_module_ranking"/>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="right"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/ivShareEntry"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginRight="5dp"
        android:layout_toLeftOf="@+id/ivUpload"
        android:src="@drawable/ic_tijiao" />

      <ImageView
        android:id="@+id/ivStop"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginRight="5dp"
        android:layout_toLeftOf="@+id/ivUpload"
        android:src="@drawable/ic_stop" />

    </LinearLayout>

  </androidx.appcompat.widget.Toolbar>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layMain"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    app:layout_constraintTop_toBottomOf="@+id/toolbar"
    app:layout_constraintBottom_toTopOf="@+id/playingProgressView">

    <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:layout_marginBottom="50dp"
      app:layout_constraintDimensionRatio="h,1:1"
      app:layout_constrainedHeight="true"
      app:layout_constrainedWidth="true"
      android:adjustViewBounds="true"
      android:background="@mipmap/bg_play_board_bg_v2"/>

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/layPlayBoard"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:layout_marginBottom="50dp"
      app:layout_constraintDimensionRatio="h,1:1"
      app:layout_constrainedHeight="true"
      app:layout_constrainedWidth="true">

      <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="1"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintVertical_bias="0.7"
        android:background="@mipmap/bg_play_board_v2"/>

      <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="1"
        app:layout_constraintDimensionRatio="h,1:1"
        app:layout_constraintVertical_bias="0.7"
        android:background="@mipmap/bg_play_scale_v2"/>

      <com.cloud.runball.widget.V2PointerView
        android:id="@+id/v2PointerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.55"
        app:layout_constraintDimensionRatio="h,1:1"
        app:startColor="#33F7DC29"
        app:centerColor="#33F7DC29"
        app:endColor="#66F83D36"
        app:ringStartColor="#F7DC29"
        app:ringCenterColor="#F7DC29"
        app:ringEndColor="#F83D36"
        app:ringWidth="16dp"
        app:angle="0"
        tools:angle="150"/>

      <com.cloud.runball.widget.SpeedCircleImageView
        android:id="@+id/ivSpeedCircle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constrainedWidth="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_percent="0.75"
        app:layout_constraintDimensionRatio="h,1:1"
        android:layout_gravity="center"
        android:adjustViewBounds="true"
        android:background="@mipmap/canvas_circle"
        android:scaleType="fitCenter"
        app:animTime="@integer/animation_duration" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/tvSpeedRPMFormat"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:textColor="#F7DC29"
        android:textSize="12sp"
        android:text="@string/play_board_speed"/>

      <com.cloud.runball.widget.MagicTextView2
        android:id="@+id/tvSpeedRPMFormat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constrainedWidth="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_percent="0.7"
        app:layout_constraintDimensionRatio="h,1:1"
        android:layout_gravity="center"
        android:gravity="center"
        android:textColor="#F7DC29"
        android:textSize="28sp"
        android:textStyle="bold"
        app:animTime="@integer/animation_duration"
        android:text="0" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tvSpeedRPMFormat"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:textColor="#F7DC29"
        android:textSize="12sp"
        android:text="@string/play_board_speed_unit"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
      android:id="@+id/lyNoticeIndex"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:gravity="center"
      android:orientation="horizontal">

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <ImageView
          android:id="@+id/imgNoticeTip"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:background="@mipmap/icon_notice_tip"
          android:clickable="true" />

        <TextView
          android:id="@+id/tvNoticeIndexTip"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginLeft="10dp"
          android:gravity="center"
          android:text="@string/tv_run_notice_tip_0"
          android:textColor="#FFFFFF"
          android:textSize="14sp" />

      </LinearLayout>

    </LinearLayout>

    <com.cloud.runball.widget.PlayingProgressView
      android:id="@+id/playingProgressView"
      android:layout_width="match_parent"
      android:layout_height="95dp"
      app:layout_constraintBottom_toBottomOf="parent"
      android:padding="20dp"
      app:bar_bg_color="#28272A"
      app:bar_progress_color_start="#F7DC29"
      app:bar_progress_color_end="#F83D36"
      app:bar_height="10dp"
      app:bar_text_color="#F7DC29"
      app:bar_start_text=""
      app:bar_start_text_padding="0dp"
      app:bar_text_size="11sp"
      app:node_size="11dp"
      app:node_color_light="#FDE833"
      app:node_color_dark="#393838"
      app:node_text_padding="8dp"
      app:node_arrive_text_color="#FFFFFF"
      app:node_arrive_text_size="12sp"
      app:progress_init="0"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

  <LinearLayout
    android:id="@+id/layNotice"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:background="@mipmap/bg_play_tip_v2"
    android:orientation="horizontal"
    android:gravity="center"
    android:visibility="invisible"
    tools:visibility="visible">

    <ImageView
      android:id="@+id/ivNoticeSwitch"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:src="@mipmap/icon_notice"/>

    <TextView
      android:id="@+id/tvNoticeTip"
      android:layout_width="wrap_content"
      android:layout_height="35dp"
      android:layout_gravity="center_vertical"
      android:layout_marginLeft="6dp"
      android:ellipsize="marquee"
      android:singleLine="true"
      android:gravity="center_vertical"
      android:textColor="#FFFFFF"
      android:textSize="14sp"
      tools:text="摇跑马拉松，1小时13分钟46秒"/>

  </LinearLayout>

  <LinearLayout
    android:id="@+id/layBottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:paddingTop="23dp"
      android:paddingBottom="28dp"
      android:gravity="center_horizontal"
      android:orientation="horizontal">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:src="@mipmap/icon_max_speed_v2"/>

        <TextView
          android:id="@+id/tvTurnHeightSpeedRPM"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingTop="5dp"
          android:paddingBottom="5dp"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="20sp"
          android:text="0" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:textColor="#F7DC29"
          android:textSize="12sp"
          android:text="@string/play_board_label_max_speed" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:src="@mipmap/icon_play_time_v2"/>

        <TextView
          android:id="@+id/tvTurnTime"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingTop="5dp"
          android:paddingBottom="5dp"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="20sp"
          android:text="00:00" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:textColor="#F7DC29"
          android:textSize="12sp"
          android:text="@string/play_board_label_turn_time" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:src="@mipmap/icon_play_distance_v2"/>

        <TextView
          android:id="@+id/tvTurnDistance"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingTop="5dp"
          android:paddingBottom="5dp"
          android:gravity="center"
          android:textColor="#ffffffff"
          android:textSize="20sp"
          android:text="0.000" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:textColor="#F7DC29"
          android:textSize="12sp"
          android:text="@string/play_board_label_turn_distance" />

      </LinearLayout>

    </LinearLayout>

    <LinearLayout
      android:id="@+id/lyAction"
      android:layout_width="match_parent"
      android:layout_height="70dp"
      android:paddingLeft="100dp"
      android:paddingRight="100dp"
      android:gravity="center"
      android:background="@mipmap/bg_play_bottom_v2"
      android:orientation="vertical">

      <TextView
        android:id="@+id/tvPower"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:drawableLeft="@mipmap/ic_power_v2"
        android:drawablePadding="5dp"
        android:gravity="center"
        android:textColor="#F7DC29"
        android:textSize="12sp"
        android:text="0%"
        android:visibility="gone"/>

      <TextView
        android:id="@+id/tvAction"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible"
        android:gravity="center"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#F7DC29"
        android:text="@string/connected_devices" />

      <TextView
        android:id="@+id/tvTip"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        tools:text="摇跑球：ddDA23232" />

    </LinearLayout>

  </LinearLayout>

</LinearLayout>