<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="81dp"
  android:paddingLeft="15dp"
  android:gravity="center_vertical"
  android:background="#28272A"
  android:orientation="horizontal">

  <ImageView
    android:id="@+id/ivIcon"
    android:layout_width="30dp"
    android:layout_height="30dp"
    tools:src="@mipmap/ic_module_ranking"/>

  <RelativeLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1">

    <LinearLayout
      android:id="@+id/lay1"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="9dp"
      android:layout_centerVertical="true"
      android:orientation="vertical">

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2.5dp"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvDistance"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="14sp"
          tools:text="距离226.223"/>

        <TextView
          android:id="@+id/tvDistanceUnit"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="11sp"
          tools:text="km"/>

      </LinearLayout>

      <TextView
        android:id="@+id/tvSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.5dp"
        android:textColor="#888888"
        android:textSize="11sp"
        tools:text="来源:摇跑打榜"/>

    </LinearLayout>

    <LinearLayout
      android:id="@+id/lay2"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_toRightOf="@+id/lay1"
      android:layout_toLeftOf="@+id/uploadStatus"
      android:layout_centerVertical="true"
      android:layout_marginLeft="20dp"
      android:orientation="vertical">

      <TextView
        android:id="@+id/tvCreateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2.5dp"
        android:textColor="#888888"
        android:textSize="11sp"
        tools:text="10/21 12:18"/>

      <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.5dp"
        android:textColor="#888888"
        android:textSize="11sp"
        tools:text="用时 00:15:25"/>

    </LinearLayout>

    <TextView
      android:id="@+id/uploadStatus"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:paddingRight="15dp"
      android:layout_alignParentRight="true"
      android:layout_centerVertical="true"
      android:textColor="#888888"
      android:textSize="12sp"
      tools:text="上传成功"/>

    <View
      android:id="@+id/vDivider"
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_alignParentBottom="true"
      android:background="#333333"/>

  </RelativeLayout>



</LinearLayout>