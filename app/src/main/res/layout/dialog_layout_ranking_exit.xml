<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/lyContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center"
        android:background="@mipmap/exit_bg"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:background="@mipmap/exit_bg_title"
            android:gravity="center"
            android:text="@string/tip"
            android:textColor="#ff85a6be"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/lvContent"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="50dp"
            android:layout_marginRight="10dp"
            android:gravity="center|top"
            android:text="@string/tip_ranking_exit"
            android:textColor="#FDFD30"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCancel"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_weight="1.0"
                android:clickable="true"
                android:gravity="center"
                android:text="@string/btn_cancel"
                android:textColor="#FBBE10"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_Confirm"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_weight="1.0"
                android:clickable="true"
                android:gravity="center"
                android:text="@string/btn_confirm2"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>

