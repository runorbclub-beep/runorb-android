<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#1A1D20">

  <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    android:background="?attr/colorPrimary"
    android:minHeight="?attr/actionBarSize"
    app:navigationIcon="@mipmap/btn_return">

    <TextView
      android:id="@+id/tvToolBarTitle"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:layout_gravity="center"
      android:textColor="@android:color/white"
      android:textSize="16sp"
      android:text="@string/title_go_module_events"/>

  </androidx.appcompat.widget.Toolbar>

  <com.to.aboomy.pager2banner.Banner
    android:id="@+id/banner"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:layout_constraintDimensionRatio="h,15:8"
    app:layout_constraintTop_toBottomOf="@+id/toolbar"
    android:background="#666666"/>

  <net.lucode.hackware.magicindicator.MagicIndicator
    android:id="@+id/magicIndicator"
    android:layout_gravity="center"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginBottom="-5dp"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:background="@drawable/bg_layout_header_radian_top"
    app:layout_constraintBottom_toBottomOf="@+id/banner"
    android:scrollIndicators="none"
    app:tabGravity="center"
    app:tabMode="fixed" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    app:layout_constraintTop_toBottomOf="@+id/banner"
    app:layout_constraintBottom_toBottomOf="parent"
    android:layout_marginTop="5dp"
    android:layout_marginLeft="15dp"
    android:layout_marginRight="15dp"
    android:orientation="vertical"
    android:background="#25282C">

    <androidx.viewpager2.widget.ViewPager2
      android:id="@+id/viewPager"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:scrollbars="none" />

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>