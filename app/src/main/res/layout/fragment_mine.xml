<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".module.mine.MineFragment">

  <com.google.android.material.appbar.AppBarLayout
    android:id="@+id/layTop"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.appbar.CollapsingToolbarLayout
      android:id="@+id/layCollapsingToolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:contentScrim="?attr/colorPrimary"
      app:layout_scrollFlags="scroll|exitUntilCollapsed"
      app:toolbarId="@+id/toolbar">

      <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
          android:layout_width="match_parent"
          android:layout_height="0dp"
          app:layout_constraintDimensionRatio="w,7:10"
          app:layout_constraintTop_toTopOf="parent"
          android:background="@mipmap/page_bg_top">

          <ImageView
            android:id="@+id/img_info_avatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintVertical_bias="0.4"
            android:layout_marginLeft="16dp"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:background="@drawable/border_ranking_portrait_top" />

          <ImageView
            android:id="@+id/ivVip"
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:layout_constraintTop_toBottomOf="@+id/img_info_avatar"
            app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
            app:layout_constraintRight_toRightOf="@+id/img_info_avatar"
            android:visibility="gone"
            tools:visibility="visible"
            android:background="@mipmap/tag_vip" />

          <TextView
            android:id="@+id/tv_info_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            app:layout_constraintTop_toTopOf="@+id/img_info_avatar"
            app:layout_constraintBottom_toTopOf="@+id/layUserInfo"
            app:layout_constraintLeft_toRightOf="@+id/img_info_avatar"
            android:drawablePadding="2dp"
            android:gravity="center_vertical"
            android:textColor="#ffffffff"
            android:textSize="16sp"
            tools:drawableLeft="@mipmap/ic_man"
            tools:text="@string/lbl_default_name" />

          <LinearLayout
            android:id="@+id/layUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_info_nickname"
            app:layout_constraintBottom_toBottomOf="@+id/img_info_avatar"
            app:layout_constraintLeft_toRightOf="@+id/img_info_avatar"
            android:dividerPadding="3dp"
            android:showDividers="middle"
            android:divider="@drawable/divider_horizontal_dddd"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/tvAge"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="7dp"
              android:layout_marginRight="7dp"
              android:singleLine="true"
              android:textColor="#DDDDDD"
              android:textSize="12sp"
              tools:text="10岁"/>

<!--            <View-->
<!--              android:id="@+id/divider1"-->
<!--              android:layout_width="1dp"-->
<!--              android:layout_height="11dp"-->
<!--              android:layout_marginLeft="7dp"-->
<!--              android:background="#DDDDDD"/>-->

            <TextView
              android:id="@+id/tvArea"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="7dp"
              android:layout_marginRight="7dp"
              android:singleLine="true"
              android:textColor="#DDDDDD"
              android:textSize="12sp"
              tools:text="深圳" />

            <TextView
              android:id="@+id/tvWeixin"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="7dp"
              android:layout_marginRight="7dp"
              android:singleLine="true"
              android:textColor="#DDDDDD"
              android:textSize="12sp"
              tools:text="微信号:Y323787834" />

          </LinearLayout>

          <TextView
            android:id="@+id/tv_info_sign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            app:layout_constraintWidth="match_parent"
            app:layout_constraintTop_toBottomOf="@+id/img_info_avatar"
            app:layout_constraintLeft_toLeftOf="parent"
            android:singleLine="true"
            android:textColor="#ff767779"
            android:textSize="12sp"
            tools:text="@string/lbl_default_sign" />

          <ImageView
            android:id="@+id/ivBgScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.3"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:background="@mipmap/bg_accumulate_points"/>

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@+id/ivBgScore"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:gravity="center"
            android:paddingLeft="20dp"
            android:paddingTop="18dp"
            android:paddingRight="20dp"
            android:paddingBottom="18dp"
            android:orientation="horizontal">

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#28272A"
              android:textSize="16sp"
              android:textStyle="bold"
              android:text="@string/turn_exponent_2"/>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#28272A"
              android:textSize="16sp"
              android:textStyle="bold"
              android:text="(ei):"/>

            <TextView
              android:id="@+id/tvExponent"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginLeft="5dp"
              android:textColor="#28272A"
              android:textSize="16sp"
              android:textStyle="bold"
              android:text="0" />

          </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

      </androidx.constraintlayout.widget.ConstraintLayout>

      <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_collapseMode="pin">

        <RelativeLayout
          android:layout_width="match_parent"
          android:layout_height="?attr/actionBarSize">

          <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:textColor="#FFFFFF"
            tools:text="aaa" />

