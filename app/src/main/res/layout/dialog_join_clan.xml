<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center">

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center">

    <ImageView
      android:id="@+id/ivClose"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentEnd="true"
      android:layout_marginRight="22dp"
      android:layout_marginBottom="17dp"
      android:contentDescription="@null"
      android:src="@mipmap/close_gray" />

    <LinearLayout
      android:id="@+id/layMain"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="22dp"
      android:layout_marginRight="22dp"
      android:orientation="vertical"
      android:layout_below="@+id/ivClose"
      android:background="@drawable/bg_dialog_select_team">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#F7DC29"
        android:text="@string/clan_apply_join"/>

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textColor="#ADADAD"
        android:text="@string/tip_clan_apply_join"/>

      <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:cardCornerRadius="4dp"
        app:cardBackgroundColor="#28272A">

        <EditText
          android:id="@+id/etInfo"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="20dp"
          android:layout_marginBottom="20dp"
          android:layout_marginStart="15dp"
          android:layout_marginEnd="15dp"
          android:lines="5"
          android:background="@null"
          android:hint="@string/hint_clan_apply_join"
          android:gravity="left"
          android:textColorHint="#ADADAD"
          android:textColor="#ADADAD"
          android:textSize="14sp"/>

      </androidx.cardview.widget.CardView>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/tvSubmit"
          android:layout_width="226dp"
          android:layout_height="wrap_content"
          android:paddingTop="8dp"
          android:paddingBottom="8dp"
          android:paddingLeft="36dp"
          android:paddingRight="36dp"
          android:gravity="center"
          android:background="@drawable/selector_radius_yellow"
          android:textColor="#25282C"
          android:textSize="14sp"
          android:text="@string/btn_ok"/>

      </LinearLayout>

    </LinearLayout>

  </RelativeLayout>

</FrameLayout>