<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="190dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@mipmap/other_main_match_section"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivHorse"
            android:layout_width="158dp"
            android:layout_height="158dp"
            android:layout_centerVertical="true"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            android:background="@drawable/anima_horse_1"
            />

        <LinearLayout
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="50dp"
            android:layout_gravity="right|center_vertical"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvHorseName"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="@string/lbl_input_match_horse"
                android:gravity="center"
                android:textColor="#ff00fff1"
                android:textSize="18sp"
                />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#00E9F3"
                />

            <TextView
                android:id="@+id/tvHorseAttachPerson"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_input_match_person_num"
                android:drawablePadding="10dp"
                android:layout_gravity="center"
                android:drawableLeft="@mipmap/other_main_match_person"
                android:layout_marginTop="10dp"
                android:gravity="left|center"
                android:textColor="#fffce322"
                android:textSize="18sp"
                />
        </LinearLayout>


    </RelativeLayout>

    <ImageView
        android:id="@+id/ivConfirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-20dp"
        android:clickable="true"
        android:layout_gravity="center|bottom"
        android:background="@mipmap/win_btn_confirm" />

</FrameLayout>