<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/layContent"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:minHeight="?attr/actionBarSize">

    <ImageView
      android:id="@+id/ivSearch"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_centerVertical="true"
      android:layout_gravity="center"
      android:layout_marginLeft="10dp"
      android:src="@mipmap/ic_serach"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_centerInParent="true"
      android:text="@string/title_homepage_rank_list"
      android:textColor="@android:color/white"
      android:textSize="16sp" />

    <TextView
      android:id="@+id/tvArea"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentBottom="true"
      android:layout_centerInParent="true"
      android:textColor="#FFF6A7"
      android:textSize="12sp"
      tools:text="(全国总榜)" />

    <ImageView
      android:id="@+id/tvMenu"
      android:layout_width="26dp"
      android:layout_height="26dp"
      android:layout_alignParentRight="true"
      android:layout_centerVertical="true"
      android:layout_gravity="center"
      android:layout_marginRight="10dp"
      android:src="@mipmap/filter" />

  </RelativeLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp">

    <com.to.aboomy.pager2banner.Banner
      android:id="@+id/banner"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintDimensionRatio="h,25:8"
      android:background="#666666"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

  <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    app:cardBackgroundColor="#28272A"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:showDividers="middle"
      android:divider="@drawable/divider_horizontal"
      android:dividerPadding="4dp"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/tabPersonalRank"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#F7DC29"
        android:text="@string/tab_personal_rank"/>

      <TextView
        android:id="@+id/tabClanRank"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#888888"
        android:text="@string/tab_clan_rank"/>

    </LinearLayout>

  </androidx.cardview.widget.CardView>

  <net.lucode.hackware.magicindicator.MagicIndicator
    android:id="@+id/personalIndicator"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    app:tabGravity="fill"
    app:tabMode="fixed"
    android:visibility="gone"
    tools:visibility="visible"/>

  <androidx.viewpager2.widget.ViewPager2
    android:id="@+id/personalViewPager"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:scrollbars="none"
    android:visibility="gone"
    tools:visibility="visible" />

  <net.lucode.hackware.magicindicator.MagicIndicator
    android:id="@+id/teamIndicator"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    app:tabGravity="fill"
    app:tabMode="fixed"
    android:visibility="gone" />

  <androidx.viewpager2.widget.ViewPager2
    android:id="@+id/teamViewPager"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:scrollbars="none"
    android:visibility="gone" />

</LinearLayout>