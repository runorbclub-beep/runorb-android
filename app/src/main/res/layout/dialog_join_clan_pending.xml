<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:gravity="center"
  android:orientation="vertical">

  <ImageView
    android:id="@+id/ivClose"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="end"
    android:layout_marginRight="30dp"
    android:layout_marginBottom="17dp"
    android:contentDescription="@null"
    android:src="@mipmap/close_gray" />

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="332dp"
    android:layout_height="366dp"
    android:background="@mipmap/bg_dialog">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toTopOf="@+id/tvInfo"
      android:gravity="center"
      android:textSize="16sp"
      android:textColor="#F7DC29"
      android:text="@string/title_pending_clan_member"/>

    <TextView
      android:id="@+id/tvInfo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:layout_marginStart="30dp"
      android:layout_marginEnd="30dp"
      android:gravity="center"
      android:textColor="#FFFFFF"
      android:textSize="14sp"
      tools:text="加入备注：XXXX俱乐部成员XXX，请通过！"/>

    <TextView
      android:id="@+id/tvFail"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:paddingTop="8dp"
      android:paddingBottom="8dp"
      android:paddingLeft="36dp"
      android:paddingRight="36dp"
      android:gravity="center"
      app:layout_constraintTop_toBottomOf="@+id/tvInfo"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toLeftOf="@+id/tvPass"
      android:background="@drawable/selector_match_btn_sign_up_3"
      android:textColor="#25282C"
      android:textSize="18sp"
      android:text="@string/btn_pending_fail"/>

    <TextView
      android:id="@+id/tvPass"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:paddingTop="8dp"
      android:paddingBottom="8dp"
      android:paddingLeft="36dp"
      android:paddingRight="36dp"
      android:gravity="center"
      app:layout_constraintTop_toBottomOf="@+id/tvInfo"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toRightOf="@+id/tvFail"
      app:layout_constraintRight_toRightOf="parent"
      android:background="@drawable/selector_match_btn_sign_up"
      android:textColor="#25282C"
      android:textSize="18sp"
      android:text="@string/btn_pending_pass"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>