<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <ImageView
    android:id="@+id/ivClose"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_above="@+id/layContent"
    android:layout_alignRight="@+id/layContent"
    android:layout_marginBottom="14dp"
    android:src="@mipmap/close_gray"/>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="20dp"
    android:layout_marginRight="20dp"
    android:layout_centerInParent="true"
    android:background="@mipmap/bg_dialog"
    android:orientation="vertical">

    <TextView
      android:id="@+id/tvTile"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="50dp"
      android:textSize="16sp"
      android:textColor="#F7DC29"
      android:text="@string/btn_add_target"/>

    <TextView
      android:id="@+id/tvStartMonth"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@+id/tvTile"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="36dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      tools:text="2021年11月开始"/>

    <EditText
      android:id="@+id/etMonth"
      android:layout_width="150dp"
      android:layout_height="36dp"
      app:layout_constraintTop_toBottomOf="@+id/tvStartMonth"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="22dp"
      android:background="#28272A"
      android:gravity="center"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:textColorHint="#66FFFFFF"
      android:inputType="number"
      android:hint="1"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etMonth"
      app:layout_constraintBottom_toBottomOf="@+id/etMonth"
      app:layout_constraintRight_toLeftOf="@+id/etMonth"
      android:layout_marginRight="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="@string/continuity"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etMonth"
      app:layout_constraintBottom_toBottomOf="@+id/etMonth"
      app:layout_constraintLeft_toRightOf="@+id/etMonth"
      android:layout_marginLeft="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="@string/n_month"/>

    <EditText
      android:id="@+id/etDay"
      android:layout_width="150dp"
      android:layout_height="36dp"
      app:layout_constraintTop_toBottomOf="@+id/etMonth"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="18dp"
      android:background="#28272A"
      android:gravity="center"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:textColorHint="#66FFFFFF"
      android:inputType="number"
      android:hint="20"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etDay"
      app:layout_constraintBottom_toBottomOf="@+id/etDay"
      app:layout_constraintRight_toLeftOf="@+id/etDay"
      android:layout_marginRight="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="@string/monthly"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etDay"
      app:layout_constraintBottom_toBottomOf="@+id/etDay"
      app:layout_constraintLeft_toRightOf="@+id/etDay"
      android:layout_marginLeft="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="@string/day"/>

    <EditText
      android:id="@+id/etDistance"
      android:layout_width="150dp"
      android:layout_height="36dp"
      app:layout_constraintTop_toBottomOf="@+id/etDay"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="18dp"
      android:background="#28272A"
      android:gravity="center"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:textColorHint="#66FFFFFF"
      android:inputType="number"
      android:hint="20"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etDistance"
      app:layout_constraintBottom_toBottomOf="@+id/etDistance"
      app:layout_constraintRight_toLeftOf="@+id/etDistance"
      android:layout_marginRight="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="@string/every_day"/>

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="@+id/etDistance"
      app:layout_constraintBottom_toBottomOf="@+id/etDistance"
      app:layout_constraintLeft_toRightOf="@+id/etDistance"
      android:layout_marginLeft="20dp"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:text="km"/>

    <TextView
      android:id="@+id/tvSubmit"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@+id/etDistance"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:layout_marginTop="68dp"
      android:layout_marginBottom="30dp"
      android:paddingTop="11dp"
      android:paddingBottom="11dp"
      android:paddingLeft="99dp"
      android:paddingRight="99dp"
      android:background="@drawable/selector_match_btn_sign_up"
      android:textStyle="bold"
      android:textColor="#25282C"
      android:textSize="14sp"
      android:text="@string/finish"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>