<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

  <item android:state_pressed="true">
    <shape>
      <stroke
        android:color="#767779"
        android:width="1dp"/>
      <corners android:radius="20dp"/>
      <gradient
        android:angle="270"
        android:type="linear"
        android:startColor="#F9E85B"
        android:centerColor="#F9E85B"
        android:endColor="#F5BE5A"/>
    </shape>
  </item>

  <item android:state_checked="true">
    <shape>
      <stroke
        android:color="#767779"
        android:width="1dp"/>
      <corners android:radius="20dp"/>
      <gradient
        android:angle="270"
        android:type="linear"
        android:startColor="#F9E85B"
        android:centerColor="#F9E85B"
        android:endColor="#F5BE5A"/>
    </shape>
  </item>

  <item>
    <shape>
      <stroke
        android:color="#767779"
        android:width="1dp"/>
      <corners android:radius="20dp"/>
      <solid android:color="#1a1d20"/>
    </shape>
  </item>
</selector>