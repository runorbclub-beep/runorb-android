<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#0037393F" />
        </shape>
    </item>
    <!--  进度条的背景色-->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient
                    android:type="linear"
                    android:useLevel="true"
                    android:startColor="#66BD00A6"
                    android:endColor="#0087026A"
                    android:centerX="0.5"
                    android:centerY="0.5"
                    android:angle="0" />
            </shape>
        </clip>
    </item>
</layer-list>