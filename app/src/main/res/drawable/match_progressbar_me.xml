<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#0037393F" />
        </shape>
    </item>
    <!--  进度条的背景色-->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient
                    android:type="linear"
                    android:useLevel="true"
                    android:startColor="#004b59d6"
                    android:centerColor="#38A20886"
                    android:endColor="#ccA20886"
                    android:centerX="0"
                    android:centerY="0"
                    android:angle="0" />
            </shape>
        </clip>
    </item>
</layer-list>