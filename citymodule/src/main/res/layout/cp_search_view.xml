<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cp_search_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/city_module_selector_search_city"
    android:gravity="center_vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/cp_search_box"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@null"
        android:drawableLeft="@mipmap/city_module_search"
        android:hint="?attr/cpSearchHintText"
        android:maxLength="20"
        android:maxLines="1"
        android:textCursorDrawable="?attr/cpSearchCursorDrawable"
        android:textColor="#ff767779"
        android:textColorHint="#ff767779"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/ivDelete"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginRight="20dp"
        android:scaleType="fitCenter"
        android:background="@mipmap/city_module_delete" />


</LinearLayout>